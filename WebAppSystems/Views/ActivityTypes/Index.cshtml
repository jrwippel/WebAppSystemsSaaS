@model IEnumerable<WebAppSystems.Models.ActivityType>

@{
    ViewData["Title"] = "Tipos de Atividade";
}

<div class="container-fluid px-4">
    <!-- Header com gradiente -->
    <div class="card border-0 shadow-sm mb-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
        <div class="card-body text-white py-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-2">
                        <i class="fas fa-tags me-2"></i>Tipos de Atividade
                    </h2>
                    <p class="mb-0 opacity-90">Gerencie os tipos de atividade personalizados para seu escritório</p>
                </div>
                <a asp-action="Create" class="btn btn-light btn-lg">
                    <i class="fas fa-plus me-2"></i>Novo Tipo
                </a>
            </div>
        </div>
    </div>

    <!-- Mensagens -->
    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["MensagemSucesso"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["MensagemErro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["MensagemErro"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Lista de Tipos -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 50px;"></th>
                                <th>Nome</th>
                                <th>Descrição</th>
                                <th style="width: 100px;">Ordem</th>
                                <th style="width: 100px;">Status</th>
                                <th style="width: 150px;" class="text-end">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center">
                                        <div style="width: 30px; height: 30px; background-color: @item.Color; border-radius: 6px; border: 2px solid #e0e0e0;"></div>
                                    </td>
                                    <td>
                                        <strong>@item.Name</strong>
                                    </td>
                                    <td class="text-muted">
                                        @(string.IsNullOrEmpty(item.Description) ? "-" : item.Description)
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">@item.DisplayOrder</span>
                                    </td>
                                    <td>
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success">
                                                <i class="fas fa-check me-1"></i>Ativo
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                <i class="fas fa-times me-1"></i>Inativo
                                            </span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Editar">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Excluir">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-tags fa-3x text-muted mb-3"></i>
                    <h5 class="text-muted">Nenhum tipo de atividade cadastrado</h5>
                    <p class="text-muted">Clique em "Novo Tipo" para criar seu primeiro tipo de atividade</p>
                </div>
            }
        </div>
    </div>

    <!-- Info Box -->
    <div class="alert alert-info mt-4" role="alert">
        <i class="fas fa-info-circle me-2"></i>
        <strong>Dica:</strong> Os tipos de atividade são usados para categorizar os registros de tempo. 
        Você pode personalizar os nomes, cores e ordem de exibição conforme a necessidade do seu escritório.
    </div>
</div>
