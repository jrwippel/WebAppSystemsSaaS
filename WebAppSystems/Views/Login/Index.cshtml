@model LoginModel
@{
    Layout = "_LayoutDeslogado";
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - JRWIT Solutions</title>
    <link href="/lib/bootstrap/dist/css/bootstrap.min.css?v=2" rel="stylesheet">
    <link href="/lib/bootstrap-icons/font/bootstrap-icons.css?v=2" rel="stylesheet">
    <link href="/css/custom-styles.css?v=2" rel="stylesheet">
</head>
<body>
    <div class="login-page">
        <div class="login-wrapper">
            <!-- Left Side - Image/Branding -->
            <div class="login-left">
                <div class="brand-section">
                    <div class="brand-logo-container">
                        <div class="logo-text">
                            <div class="logo-icon-large">
                                <i class="bi bi-clock-history"></i>
                            </div>
                            <h1 class="logo-title">Time Tracker</h1>
                            <p class="logo-subtitle">Professional Time Management System</p>
                        </div>
                    </div>
                    
                    <div class="features-list">
                        <div class="feature-item">
                            <div class="feature-icon">
                                <i class="bi bi-clock-history"></i>
                            </div>
                            <div class="feature-text">
                                <h3>Time Tracking</h3>
                                <p>Track hours efficiently</p>
                            </div>
                        </div>
                        
                        <div class="feature-item">
                            <div class="feature-icon">
                                <i class="bi bi-calendar-check"></i>
                            </div>
                            <div class="feature-text">
                                <h3>Time Management</h3>
                                <p>Organize and optimize your time</p>
                            </div>
                        </div>
                        
                        <div class="feature-item">
                            <div class="feature-icon">
                                <i class="bi bi-graph-up"></i>
                            </div>
                            <div class="feature-text">
                                <h3>Reports & Analytics</h3>
                                <p>Detailed insights and reports</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Side - Login Form -->
            <div class="login-right">
                <div class="login-card">
                    <div class="login-header">
                        <div class="icon-wrapper">
                            <i class="bi bi-clock-history"></i>
                        </div>
                        <h2>Time Tracker</h2>
                        <p>Log in to your account</p>
                    </div>

                    @if (TempData["MensagemErro"] != null)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-circle"></i>
                            @TempData["MensagemErro"]
                        </div>
                    }

                    @if (TempData["MensagemSucesso"] != null)
                    {
                        <div class="alert alert-success">
                            <i class="bi bi-check-circle"></i>
                            @TempData["MensagemSucesso"]
                        </div>
                    }

                    <form asp-controller="Login" asp-action="Entrar" method="post" class="login-form">
                        <div class="form-group">
                            <label for="login">Email</label>
                            <div class="input-group">
                                <span class="input-icon">
                                    <i class="bi bi-envelope"></i>
                                </span>
                                <input type="email" 
                                       asp-for="Login" 
                                       class="form-control" 
                                       id="login" 
                                       placeholder="Digite seu email"
                                       autocomplete="email">
                            </div>
                            @Html.ValidationMessageFor(x => x.Login, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-group">
                            <label for="senha">Password</label>
                            <div class="input-group">
                                <span class="input-icon">
                                    <i class="bi bi-lock"></i>
                                </span>
                                <input type="password" 
                                       asp-for="Senha" 
                                       class="form-control" 
                                       id="senha" 
                                       placeholder="••••••"
                                       autocomplete="off">
                                <button type="button" class="toggle-password" id="togglePassword">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            @Html.ValidationMessageFor(x => x.Senha, "", new { @class = "text-danger" })
                        </div>

                        <button type="submit" class="btn-login">
                            Sign In
                            <i class="bi bi-arrow-right"></i>
                        </button>
                    </form>

                    <div class="login-footer">
                        <a asp-action="RedefinirSenha" asp-controller="Login" class="forgot-link">
                            <i class="bi bi-key"></i>
                            Forgot your password?
                        </a>
                    </div>

                    <div class="login-footer" style="margin-top: 15px; padding-top: 15px; border-top: 1px solid #e0e0e0;">
                        <p style="text-align: center; color: #666; margin-bottom: 10px;">
                            Don't have an account?
                        </p>
                        <a asp-action="Index" asp-controller="Registro" class="btn btn-outline-primary" style="width: 100%; border-radius: 10px; padding: 12px; font-weight: 600;">
                            <i class="bi bi-person-plus"></i>
                            Create Free Account
                        </a>
                    </div>
                </div>

                <div class="brand-footer">
                    <a href="https://jrwippel.github.io/WebAppSystems/" target="_blank" class="brand-text">JRWIT.COM</a>
                    <span class="brand-tagline">SMART SOLUTIONS FOR YOUR BUSINESS</span>
                </div>
            </div>
        </div>
    </div>

    <script src="/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Toggle Password
        document.getElementById('togglePassword')?.addEventListener('click', function() {
            const passwordInput = document.getElementById('senha');
            const icon = this.querySelector('i');
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                passwordInput.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        });
    </script>
</body>
</html>



