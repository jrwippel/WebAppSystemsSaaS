@model RedefinirSenhaModel
@{
    Layout = "_LayoutDeslogado";
    ViewData["Title"] = "Redefinir Senha";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Redefinir Senha - JRWIT Solutions</title>
    <link href="/lib/bootstrap/dist/css/bootstrap.min.css?v=2" rel="stylesheet">
    <link href="/lib/bootstrap-icons/font/bootstrap-icons.css?v=2" rel="stylesheet">
    <link href="/css/custom-styles.css?v=3" rel="stylesheet">
</head>
<body>
    <div class="login-page">
        <div class="login-wrapper">
            <!-- Left Side - Branding -->
            <div class="login-left">
                <div class="brand-section">
                    <div class="brand-logo-container">
                        <div class="logo-text">
                            <div class="logo-icon-large">
                                <i class="bi bi-shield-lock"></i>
                            </div>
                            <h1 class="logo-title">Time Tracker</h1>
                            <p class="logo-subtitle">Recupere o acesso à sua conta</p>
                        </div>
                    </div>

                    <div class="features-list">
                        <div class="feature-item">
                            <div class="feature-icon">
                                <i class="bi bi-envelope-check"></i>
                            </div>
                            <div class="feature-text">
                                <h3>Envio por Email</h3>
                                <p>Nova senha enviada para seu email</p>
                            </div>
                        </div>
                        <div class="feature-item">
                            <div class="feature-icon">
                                <i class="bi bi-lock-fill"></i>
                            </div>
                            <div class="feature-text">
                                <h3>Troca Obrigatória</h3>
                                <p>Defina uma senha pessoal no primeiro acesso</p>
                            </div>
                        </div>
                        <div class="feature-item">
                            <div class="feature-icon">
                                <i class="bi bi-shield-check"></i>
                            </div>
                            <div class="feature-text">
                                <h3>Acesso Seguro</h3>
                                <p>Seus dados protegidos com criptografia</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Side - Form -->
            <div class="login-right">
                <div class="login-card">
                    <div class="login-header">
                        <div class="icon-wrapper">
                            <i class="bi bi-key-fill"></i>
                        </div>
                        <h2>Esqueceu a senha?</h2>
                        <p>Informe seu usuário e email para receber uma nova senha</p>
                    </div>

                    @if (TempData["MensagemErro"] != null)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-circle"></i>
                            @TempData["MensagemErro"]
                        </div>
                    }

                    @if (TempData["MensagemSucesso"] != null)
                    {
                        <div class="alert alert-success">
                            <i class="bi bi-check-circle"></i>
                            @TempData["MensagemSucesso"]
                        </div>
                    }

                    <form asp-controller="Login" asp-action="EnviarLinkParaRedefinirSenha" method="post" class="login-form">
                        <div class="form-group">
                            <label for="login">Usuário</label>
                            <div class="input-group">
                                <span class="input-icon">
                                    <i class="bi bi-person"></i>
                                </span>
                                <input type="text"
                                       asp-for="Login"
                                       class="form-control"
                                       id="login"
                                       placeholder="Digite seu usuário"
                                       autocomplete="username">
                            </div>
                            @Html.ValidationMessageFor(x => x.Login, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-group">
                            <label for="email">Email</label>
                            <div class="input-group">
                                <span class="input-icon">
                                    <i class="bi bi-envelope"></i>
                                </span>
                                <input type="email"
                                       asp-for="Email"
                                       class="form-control"
                                       id="email"
                                       placeholder="Digite seu email cadastrado"
                                       autocomplete="email">
                            </div>
                            @Html.ValidationMessageFor(x => x.Email, "", new { @class = "text-danger" })
                        </div>

                        <button type="submit" class="btn-login">
                            Enviar Nova Senha
                            <i class="bi bi-send"></i>
                        </button>
                    </form>

                    <div class="login-footer">
                        <a asp-controller="Login" asp-action="Index" class="forgot-link">
                            <i class="bi bi-arrow-left"></i>
                            Voltar para o Login
                        </a>
                    </div>
                </div>

                <div class="brand-footer">
                    <a href="https://jrwippel.github.io/WebAppSystems/" target="_blank" class="brand-text">JRWIT.COM</a>
                    <span class="brand-tagline">SMART SOLUTIONS FOR YOUR BUSINESS</span>
                </div>
            </div>
        </div>
    </div>

    <script src="/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
