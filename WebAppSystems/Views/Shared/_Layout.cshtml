        // Idioma atual
        let currentLang = localStorage.getItem('systemLang') || 'pt';

        // Função para trocar idioma
        function changeLanguage(lang) {
            currentLang = lang;
            localStorage.setItem('systemLang', lang);

            // Atualizar todos os elementos com data-i18n
            document.querySelectorAll('[data-i18n]').forEach(element => {
                const key = element.getAttribute('data-i18n');
                if (translations[lang] && translations[lang][key]) {
                    element.textContent = translations[lang][key];
                }
            });

            // Atualizar placeholders
            document.querySelectorAll('[data-i18n-placeholder]').forEach(element => {
                const key = element.getAttribute('data-i18n-placeholder');
                if (translations[lang] && translations[lang][key]) {
                    element.placeholder = translations[lang][key];
                }
            });

            // Atualizar botões ativos
            document.querySelectorAll('.flag-btn').forEach(btn => {
                btn.classList.remove('active');
                if (btn.getAttribute('data-lang') === lang) {
                    btn.classList.add('active');
                }
            });
        }

        // Inicializar quando o DOM estiver pronto
        document.addEventListener('DOMContentLoaded', function() {
            // Aplicar idioma salvo
            changeLanguage(currentLang);

            // Adicionar listeners aos botões de bandeira
            document.querySelectorAll('.flag-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const lang = this.getAttribute('data-lang');
                    changeLanguage(lang);
                });
            });
        });
    </script>

    <!-- Floating Timer Global Script -->
    <script>
        let floatingTimerInterval = null;
        let floatingStartTime = null;
        const alwaysOnTop = @(alwaysOnTop ? "true" : "false");

        // Check for active timer on page load
        document.addEventListener('DOMContentLoaded', async function() {
            let loggedUserId = '@ViewBag.LoggedUserId';
            
            // Fallback: try to get from data attribute if ViewBag is empty
            if (!loggedUserId || loggedUserId === '') {
                const userIdElement = document.querySelector('[data-user-id]');
                if (userIdElement) {
                    loggedUserId = userIdElement.getAttribute('data-user-id');
                }
            }
            
            if (loggedUserId && loggedUserId !== '') {
                try {
                    const response = await fetch(`/TimeTracker/GetActiveTimer?attorneyId=${loggedUserId}`);
                    
                    if (response.ok) {
                        const data = await response.json();
                        
                        if (data && data.horaInicial) {
                            const dateStr = data.date.split('T')[0];
                            const [year, month, day] = dateStr.split('-').map(Number);
                            const [hours, minutes, seconds] = data.horaInicial.split(':').map(Number);
                            floatingStartTime = new Date(year, month - 1, day, hours, minutes, seconds, 0);
                            
                            showFloatingTimer();
                            floatingTimerInterval = setInterval(updateFloatingTimer, 1000);
                        } else {
                            if (floatingTimerInterval) { clearInterval(floatingTimerInterval); floatingTimerInterval = null; }
                            floatingStartTime = null;
                            hideFloatingTimer();
                        }
                    } else {
                        if (floatingTimerInterval) { clearInterval(floatingTimerInterval); floatingTimerInterval = null; }
                        floatingStartTime = null;
                        hideFloatingTimer();
                    }
                } catch (error) {
                    if (floatingTimerInterval) { clearInterval(floatingTimerInterval); floatingTimerInterval = null; }
                    floatingStartTime = null;
                    hideFloatingTimer();
                }
            }
        });

        function showFloatingTimer() {
            if (!alwaysOnTop) return; // só mostra se o usuário habilitou
            const timer = document.getElementById('floatingTimer');
            if (timer) timer.style.display = 'block';
        }

        function hideFloatingTimer() {
            const timer = document.getElementById('floatingTimer');
            if (timer) timer.style.display = 'none';
        }

        function updateFloatingTimer() {
            if (!floatingStartTime) return;

            const now = new Date();
            const elapsed = Math.floor((now - floatingStartTime) / 1000);
            const hours = String(Math.floor(elapsed / 3600)).padStart(2, '0');
            const minutes = String(Math.floor((elapsed % 3600) / 60)).padStart(2, '0');
            const seconds = String(elapsed % 60).padStart(2, '0');

            const timerDisplay = document.querySelector('.floating-timer-time');
            if (timerDisplay) {
                timerDisplay.textContent = `${hours}:${minutes}:${seconds}`;
            }
        }

        async function stopFloatingTimer() {
            // Get the processRecordId from the active timer
            const loggedUserId = '@ViewBag.LoggedUserId';
            if (!loggedUserId) {
                window.location.href = '/TimeTracker/Index';
                return;
            }

            try {
                // Get active timer info
                const response = await fetch(`/TimeTracker/GetActiveTimer?attorneyId=${loggedUserId}`);
                if (response.ok) {
                    const data = await response.json();
                    if (data && data.processRecordId) {
                        // Stop the timer
                        const stopResponse = await fetch('/TimeTracker/StopTimer', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                processRecordId: data.processRecordId,
                                description: data.description
                            })
                        });

                        if (stopResponse.ok) {
                            // Stop the floating timer
                            if (window.stopFloatingTimerGlobal) {
                                window.stopFloatingTimerGlobal();
                            }
                            // Reload current page to update hours
                            window.location.reload();
                        } else {
                            console.error('Erro ao parar o cronômetro');
                            window.location.href = '/TimeTracker/Index';
                        }
                    } else {
                        window.location.href = '/TimeTracker/Index';
                    }
                } else {
                    window.location.href = '/TimeTracker/Index';
                }
            } catch (error) {
                console.error('Erro ao parar cronômetro:', error);
                window.location.href = '/TimeTracker/Index';
            }
        }

        // Expose functions globally for TimeTracker page
        window.startFloatingTimer = function(startTime) {
            floatingStartTime = startTime;
            showFloatingTimer();
            if (floatingTimerInterval) {
                clearInterval(floatingTimerInterval);
            }
            floatingTimerInterval = setInterval(updateFloatingTimer, 1000);
        };

        window.stopFloatingTimerGlobal = function() {
            if (floatingTimerInterval) {
                clearInterval(floatingTimerInterval);
                floatingTimerInterval = null;
            }
            floatingStartTime = null;
            hideFloatingTimer();
        };
    </script>
