@using Newtonsoft.Json
@using WebAppSystems.Models
@using WebAppSystems.Data
@using Microsoft.EntityFrameworkCore
@inject WebAppSystemsContext _layoutContext
@{
    bool alwaysOnTop = false;
    int? diasRestantesTrial = null;
    string sessao = Context.Session.GetString("sessaoUsuarioLogado");
    if (!string.IsNullOrEmpty(sessao))
    {
        var usuarioSessao = JsonConvert.DeserializeObject<Attorney>(sessao);
        if (usuarioSessao != null)
        {
            // Lê direto do banco para sempre ter o valor mais atual
            var usuarioDB = _layoutContext.Attorney.IgnoreQueryFilters()
                .Where(a => a.Id == usuarioSessao.Id)
                .Select(a => new { a.UseCronometroAlwaysOnTop })
                .FirstOrDefault();
            alwaysOnTop = usuarioDB?.UseCronometroAlwaysOnTop ?? false;

            // Verifica dias restantes do trial
            var tenant = _layoutContext.Tenants.Find(usuarioSessao.TenantId);
            if (tenant != null && tenant.TrialEndsAt.HasValue && tenant.SubscriptionExpiresAt == null)
            {
                var dias = (int)(tenant.TrialEndsAt.Value - DateTime.UtcNow).TotalDays;
                if (dias >= 0 && dias <= 7)
                    diasRestantesTrial = dias;
            }
        }
    }
}
