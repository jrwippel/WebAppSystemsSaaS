    <script>
        (function () {
            var overlay = document.getElementById('pageLoadingOverlay');
            var minuteHand = document.getElementById('minuteHand');
            var hourHand = document.getElementById('hourHand');
            var animFrame;
            var startTime;
            var showTimer;
            var DELAY = 350; // ms antes de mostrar o loader

            function animateClock(ts) {
                if (!startTime) startTime = ts;
                var elapsed = ts - startTime;
                var minDeg = (elapsed / 2000) * 360;
                var hourDeg = (elapsed / 24000) * 360;
                minuteHand.setAttribute('transform', 'rotate(' + minDeg + ', 30, 30)');
                hourHand.setAttribute('transform', 'rotate(' + hourDeg + ', 30, 30)');
                animFrame = requestAnimationFrame(animateClock);
            }

            function scheduleLoader() {
                // Só mostra se demorar mais de DELAY ms
                showTimer = setTimeout(function () {
                    overlay.style.display = 'flex';
                    startTime = null;
                    animFrame = requestAnimationFrame(animateClock);
                }, DELAY);
            }

            function hideLoader() {
                clearTimeout(showTimer);
                overlay.style.display = 'none';
                cancelAnimationFrame(animFrame);
                startTime = null;
            }

            window.addEventListener('pageshow', hideLoader);
            window.addEventListener('load', hideLoader);

            // Rastrear o botão que disparou o submit
            var lastSubmitButton = null;
            document.addEventListener('click', function (e) {
                var btn = e.target.closest('button[type="submit"], input[type="submit"]');
                if (btn) lastSubmitButton = btn;
            }, true);

            // Intercept link clicks
            document.addEventListener('click', function (e) {
                var el = e.target.closest('a');
                if (!el) return;
                var href = el.getAttribute('href');
                if (!href || href === '#' || href.startsWith('javascript') || href.startsWith('mailto')) return;
                if (el.getAttribute('target') === '_blank') return;
                if (el.hasAttribute('download')) return;
                if (el.getAttribute('onclick')) return;
                scheduleLoader();
            });

            // Downloads conhecidos — não mostrar loader
            var downloadActions = ['DownloadReport', 'DownloadPdfReport', 'GerarPreFatura'];

            // Intercept form submits
            document.addEventListener('submit', function (e) {
                if (e.target.tagName !== 'FORM') return;

                // Verificar se o botão tem formaction de download
                var formaction = lastSubmitButton ? lastSubmitButton.getAttribute('formaction') : null;
                if (formaction) {
                    var isDownload = downloadActions.some(function(a) { return formaction.indexOf(a) !== -1; });
                    if (isDownload) { lastSubmitButton = null; return; }
                }

                scheduleLoader();
                lastSubmitButton = null;
            });
        })();
    </script>  
     
