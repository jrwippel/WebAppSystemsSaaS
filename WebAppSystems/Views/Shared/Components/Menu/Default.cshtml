@using WebAppSystems.Models.Enums
@model Attorney

@{
    var isAdmin = Model.Perfil == ProfileEnum.Admin;
    var isControladoria = Model.Perfil == ProfileEnum.Controladoria;
    var showAdminItems = Model.Perfil != ProfileEnum.Padrao;

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";

    var adminControllers = new[] { "ValorClientes", "Attorneys", "Clients", "Departments", "Mensalistas", "Mensalista", "PercentualAreas", "ActivityTypes" };

    Func<string[], bool> isActive = controllers =>
        controllers.Any(c => string.Equals(c, currentController, StringComparison.OrdinalIgnoreCase));

    var isAdminGroupActive = adminControllers.Any(c => string.Equals(c, currentController, StringComparison.OrdinalIgnoreCase));
}

<style>
    .navbar {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
        box-shadow: 0 2px 12px rgba(102, 126, 234, 0.35);
        padding: 0 !important;
    }

    /* ── Brand / Workspace ── */
    .navbar-brand-container {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 16px;
        flex-shrink: 0;
    }

    .user-dropdown { position: relative; }

    .user-dropdown-toggle {
        background: none;
        border: none;
        color: white;
        font-weight: 600;
        font-size: 14px;
        padding: 7px 10px;
        display: flex;
        align-items: center;
        gap: 7px;
        cursor: pointer;
        border-radius: 8px;
        transition: background 0.2s;
        white-space: nowrap;
    }

    .user-dropdown-toggle:hover { background: rgba(255,255,255,0.15); }

    .dropdown-arrow {
        font-size: 11px;
        transition: transform 0.25s;
    }
    .user-dropdown.active .dropdown-arrow { transform: rotate(180deg); }

    /* ── User dropdown panel ── */
    .user-dropdown-menu {
        position: absolute;
        top: calc(100% + 8px);
        left: 0;
        background: white;
        border-radius: 12px;
        box-shadow: 0 8px 28px rgba(0,0,0,0.15);
        min-width: 260px;
        opacity: 0;
        visibility: hidden;
        transform: translateY(-8px);
        transition: all 0.25s ease;
        z-index: 2000;
    }
    .user-dropdown.active .user-dropdown-menu {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
    }

    .dropdown-header {
        padding: 14px 16px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 12px 12px 0 0;
    }
    .user-info { display: flex; align-items: center; gap: 10px; }
    .user-avatar {
        width: 42px; height: 42px;
        background: rgba(255,255,255,0.25);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 20px; flex-shrink: 0;
    }
    .user-details { color: white; }
    .user-details strong { font-size: 14px; display: block; }
    .user-email { font-size: 12px; opacity: 0.85; }

    .dropdown-divider { height: 1px; background: #e2e8f0; margin: 6px 0; }

    .dropdown-item {
        display: flex; align-items: center; gap: 10px;
        padding: 10px 16px;
        color: #2d3748; text-decoration: none;
        font-size: 14px; transition: all 0.15s;
    }
    .dropdown-item:hover { background: #f7fafc; color: #667eea; }
    .dropdown-item i { font-size: 15px; width: 18px; text-align: center; }
    .logout-item { color: #e53e3e; }
    .logout-item:hover { background: #fff5f5; color: #c53030; }

    /* ── Hours badge ── */
    .hours-today {
        display: flex; align-items: center; gap: 5px;
        padding: 5px 12px;
        background: rgba(255,255,255,0.15);
        border-radius: 20px;
        font-size: 12px; font-weight: 500;
        border: 1px solid rgba(255,255,255,0.2);
        white-space: nowrap;
        color: white;
    }
    .hours-today strong { font-weight: 700; color: #ffeb3b; }

    /* ── Nav items ── */
    .navbar-toggler {
        border-color: rgba(255,255,255,0.3) !important;
        margin: 8px 16px;
    }
    .navbar-toggler-icon {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba(255,255,255,0.9)' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e") !important;
    }

    .navbar-collapse { padding: 0 8px; }

    .navbar-nav {
        display: flex;
        flex-wrap: nowrap;
        align-items: center;
        gap: 2px;
        padding: 6px 0;
    }

    .nav-item { list-style: none; }

    .nav-link {
        color: rgba(255,255,255,0.85) !important;
        padding: 7px 10px !important;
        display: flex;
        align-items: center;
        gap: 6px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        transition: all 0.2s;
        white-space: nowrap;
        text-decoration: none;
    }
    .nav-link i { font-size: 15px; }
    .nav-link:hover {
        background: rgba(255,255,255,0.15) !important;
        color: white !important;
    }
    .nav-link.active-page {
        background: rgba(255,255,255,0.22) !important;
        color: white !important;
        font-weight: 600;
        box-shadow: inset 0 0 0 1px rgba(255,255,255,0.3);
    }
    .nav-link.active-page i { opacity: 1; }

    /* ── Gerenciar dropdown ── */
    .nav-dropdown { position: relative; }

    .nav-dropdown-menu {
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        background: white;
        border-radius: 10px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.13);
        min-width: 200px;
        opacity: 0;
        visibility: hidden;
        transform: translateY(-6px);
        transition: all 0.2s ease;
        z-index: 2000;
        padding: 6px 0;
    }
    .nav-dropdown:hover .nav-dropdown-menu,
    .nav-dropdown.active .nav-dropdown-menu {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
    }

    .nav-dropdown-item {
        display: flex; align-items: center; gap: 10px;
        padding: 9px 16px;
        color: #2d3748; text-decoration: none;
        font-size: 13px; transition: all 0.15s;
    }
    .nav-dropdown-item:hover { background: #f7fafc; color: #667eea; }
    .nav-dropdown-item i { font-size: 14px; width: 16px; text-align: center; color: #667eea; }
    .nav-dropdown-divider { height: 1px; background: #e2e8f0; margin: 4px 0; }

    .nav-dropdown-label {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        color: #a0aec0;
        padding: 6px 16px 2px;
    }

    /* ── Right side: logo + flags ── */
    .nav-right {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 12px;
        padding-right: 4px;
    }

    .company-logo-container {
        display: flex; align-items: center; justify-content: center;
        padding: 3px 8px;
        background: rgba(255,255,255,0.95);
        border-radius: 6px;
        max-height: 34px;
    }
    .company-logo { max-height: 26px; max-width: 100px; object-fit: contain; }

    .company-name-only {
        font-size: 11px; font-weight: 700; color: white;
        text-transform: uppercase; letter-spacing: 0.8px;
        padding: 5px 10px;
        background: rgba(255,255,255,0.18);
        border-radius: 6px;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        max-width: 130px;
    }

    .language-flags-group {
        display: flex; gap: 4px;
        padding: 3px;
        background: rgba(0,0,0,0.1);
        border-radius: 6px;
    }
    .flag-btn {
        background: rgba(255,255,255,0.12);
        border: 1px solid rgba(255,255,255,0.2);
        cursor: pointer;
        padding: 2px 4px;
        border-radius: 4px;
        transition: all 0.2s;
        opacity: 0.65;
        width: 30px; height: 20px;
        display: flex; align-items: center; justify-content: center;
    }
    .flag-icon { width: 20px; height: 13px; border-radius: 2px; }
    .flag-btn:hover { opacity: 1; background: rgba(255,255,255,0.22); }
    .flag-btn.active { opacity: 1; background: rgba(255,255,255,0.3); border-color: rgba(255,255,255,0.5); }

    @@media (max-width: 768px) {
        .navbar-nav { flex-wrap: wrap; padding: 8px 4px; }
        .nav-right { margin-left: 0; padding: 8px 4px; }
        .nav-dropdown-menu { position: static; box-shadow: none; opacity: 1; visibility: visible; transform: none; background: rgba(255,255,255,0.08); border-radius: 8px; margin: 4px 0; }
        .nav-dropdown-item { color: rgba(255,255,255,0.9); }
        .nav-dropdown-item:hover { background: rgba(255,255,255,0.1); color: white; }
        .nav-dropdown-label { color: rgba(255,255,255,0.5); }
        .nav-dropdown-divider { background: rgba(255,255,255,0.15); }
    }
</style>

<!-- ── Brand / Workspace dropdown ── -->
<div class="navbar-brand-container">
    <div class="user-dropdown" id="userDropdown">
        <button class="user-dropdown-toggle" id="userDropdownToggle">
            <span>👤</span>
            @Model.Name's <span data-i18n="menu.workspace">workspace</span>
            <i class="bi bi-chevron-down dropdown-arrow"></i>
        </button>

        <div class="user-dropdown-menu">
            <div class="dropdown-header">
                <div class="user-info">
                    <div class="user-avatar">👤</div>
                    <div class="user-details">
                        <strong>@Model.Name</strong>
                        <span class="user-email">@Model.Login</span>
                    </div>
                </div>
            </div>

            <div class="dropdown-divider"></div>

            <a class="dropdown-item" asp-controller="AlterarSenha" asp-action="Index">
                <i class="bi bi-shield-lock"></i>
                <span data-i18n="menu.senha">Senha</span>
            </a>
            <a class="dropdown-item" asp-controller="Parametros" asp-action="Index">
                <i class="bi bi-gear"></i>
                <span data-i18n="menu.configuracoes">Configurações</span>
            </a>
            @if (isAdmin)
            {
                <a class="dropdown-item" asp-controller="ActivityTypes" asp-action="Index">
                    <i class="bi bi-tags"></i>
                    <span data-i18n="menu.activitytypes">Tipos de Atividade</span>
                </a>
            }
            <a class="dropdown-item" asp-controller="Home" asp-action="About">
                <i class="bi bi-info-circle"></i>
                <span data-i18n="menu.about">Sobre</span>
            </a>

            <div class="dropdown-divider"></div>

            <a class="dropdown-item logout-item" asp-controller="Login" asp-action="Sair">
                <i class="bi bi-box-arrow-right"></i>
                <span data-i18n="menu.sair">Sair</span>
            </a>
        </div>
    </div>

    <div class="hours-today">
        <i class="bi bi-clock-history"></i>
        <span data-i18n="menu.hourstoday">Hoje:</span>
        <strong>@ViewBag.HorasHoje.ToString("F1")h</strong>
    </div>
</div>

<!-- ── Mobile toggler ── -->
<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
        aria-expanded="false" aria-label="Toggle navigation">
    <span class="navbar-toggler-icon"></span>
</button>

<!-- ── Nav links ── -->
<div class="navbar-collapse collapse d-sm-inline-flex">
    <ul class="navbar-nav">

        <li class="nav-item">
            <a class="nav-link @(isActive(new[]{"Home"}) ? "active-page" : "")"
               asp-controller="Home" asp-action="Index">
                <i class="bi bi-house-door"></i>
                <span data-i18n="menu.home">Home</span>
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link @(isActive(new[]{"TimeTracker"}) ? "active-page" : "")"
               asp-controller="TimeTracker" asp-action="Index">
                <i class="bi bi-stopwatch"></i>
                <span data-i18n="menu.timetracker">Time Tracker</span>
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link @(isActive(new[]{"ProcessRecord"}) ? "active-page" : "")"
               asp-controller="ProcessRecord" asp-action="Index">
                <i class="bi bi-file-earmark-bar-graph"></i>
                <span data-i18n="menu.relatorios">Relatórios</span>
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link @(isActive(new[]{"ProcessRecords"}) ? "active-page" : "")"
               asp-controller="ProcessRecords" asp-action="Index">
                <i class="bi bi-list-check"></i>
                <span data-i18n="menu.atividades">Atividades</span>
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link @(isActive(new[]{"Calendar"}) ? "active-page" : "")"
               asp-controller="Calendar" asp-action="Index">
                <i class="bi bi-calendar3"></i>
                <span data-i18n="menu.calendario">Calendário</span>
            </a>
        </li>

        @if (showAdminItems)
        {
            <!-- Gerenciar dropdown -->
            <li class="nav-item nav-dropdown" id="manageDropdown">
                <a class="nav-link @(isAdminGroupActive ? "active-page" : "")" href="#"
                   onclick="toggleManageDropdown(event)">
                    <i class="bi bi-grid"></i>
                    <span>Gerenciar</span>
                    <i class="bi bi-chevron-down" style="font-size:10px; margin-left:2px;"></i>
                </a>
                <div class="nav-dropdown-menu">
                    <div class="nav-dropdown-label">Cadastros</div>
                    <a class="nav-dropdown-item" asp-controller="Attorneys" asp-action="Index">
                        <i class="bi bi-people"></i>
                        <span data-i18n="menu.usuarios">Usuários</span>
                    </a>
                    <a class="nav-dropdown-item" asp-controller="Clients" asp-action="Index">
                        <i class="bi bi-person-badge"></i>
                        <span data-i18n="menu.clientes">Clientes</span>
                    </a>
                    <a class="nav-dropdown-item" asp-controller="Departments" asp-action="Index">
                        <i class="bi bi-building"></i>
                        <span data-i18n="menu.area">Área</span>
                    </a>

                    @if (isAdmin)
                    {
                        <div class="nav-dropdown-divider"></div>
                        <div class="nav-dropdown-label">Financeiro</div>
                        <a class="nav-dropdown-item" asp-controller="ValorClientes" asp-action="Index">
                            <i class="bi bi-cash-coin"></i>
                            <span data-i18n="menu.valores">Valores</span>
                        </a>
                        <a class="nav-dropdown-item" asp-controller="Mensalistas" asp-action="Index">
                            <i class="bi bi-calendar-check"></i>
                            <span data-i18n="menu.mensalistas">Mensalistas</span>
                        </a>
                        <a class="nav-dropdown-item" asp-controller="Mensalista" asp-action="Index">
                            <i class="bi bi-graph-up-arrow"></i>
                            <span data-i18n="menu.resultados">Resultados</span>
                        </a>
                        <a class="nav-dropdown-item" asp-controller="PercentualAreas" asp-action="Index">
                            <i class="bi bi-percent"></i>
                            <span data-i18n="menu.percentuais">Percentuais</span>
                        </a>
                    }
                </div>
            </li>
        }

        <!-- Right side: logo + flags -->
        <li class="nav-item nav-right">
            @if (ViewBag.CompanyLogo != null && ViewBag.CompanyLogo.LogoData != null)
            {
                var parametros = ViewBag.CompanyLogo as WebAppSystems.Models.Parametros;
                var base64Image = Convert.ToBase64String(parametros.LogoData);
                var imgSrc = $"data:{parametros.LogoMimeType};base64,{base64Image}";
                <div class="company-logo-container">
                    <img src="@imgSrc" alt="Logo" class="company-logo" />
                </div>
            }
            else if (ViewBag.TenantName != null)
            {
                <div class="company-name-only">@ViewBag.TenantName</div>
            }

            <div class="language-flags-group">
                <button class="flag-btn active" data-lang="pt" title="Português">
                    <svg class="flag-icon" viewBox="0 0 36 24" xmlns="http://www.w3.org/2000/svg">
                        <rect width="36" height="24" fill="#009b3a"/>
                        <path d="M18 3 L33 12 L18 21 L3 12 Z" fill="#fedf00"/>
                        <circle cx="18" cy="12" r="4" fill="#002776"/>
                    </svg>
                </button>
                <button class="flag-btn" data-lang="en" title="English">
                    <svg class="flag-icon" viewBox="0 0 36 24" xmlns="http://www.w3.org/2000/svg">
                        <rect width="36" height="24" fill="#012169"/>
                        <path d="M0 0 L36 24 M36 0 L0 24" stroke="#fff" stroke-width="4"/>
                        <path d="M0 0 L36 24 M36 0 L0 24" stroke="#C8102E" stroke-width="2.5"/>
                        <path d="M18 0 V24 M0 12 H36" stroke="#fff" stroke-width="6"/>
                        <path d="M18 0 V24 M0 12 H36" stroke="#C8102E" stroke-width="3.5"/>
                    </svg>
                </button>
                <button class="flag-btn" data-lang="es" title="Español">
                    <svg class="flag-icon" viewBox="0 0 36 24" xmlns="http://www.w3.org/2000/svg">
                        <rect width="36" height="6" fill="#AA151B"/>
                        <rect y="6" width="36" height="12" fill="#F1BF00"/>
                        <rect y="18" width="36" height="6" fill="#AA151B"/>
                    </svg>
                </button>
            </div>
        </li>

    </ul>
</div>

<script>
    // User dropdown
    document.addEventListener('DOMContentLoaded', function () {
        const toggle = document.getElementById('userDropdownToggle');
        const dropdown = document.getElementById('userDropdown');
        if (!toggle || !dropdown) return;

        toggle.addEventListener('click', function (e) {
            e.stopPropagation();
            dropdown.classList.toggle('active');
            document.getElementById('manageDropdown')?.classList.remove('active');
        });

        document.addEventListener('click', function (e) {
            if (!dropdown.contains(e.target)) dropdown.classList.remove('active');
        });
    });

    // Manage dropdown (click-based for reliability)
    function toggleManageDropdown(e) {
        e.preventDefault();
        e.stopPropagation();
        const el = document.getElementById('manageDropdown');
        el?.classList.toggle('active');
        document.getElementById('userDropdown')?.classList.remove('active');
    }

    document.addEventListener('click', function (e) {
        const el = document.getElementById('manageDropdown');
        if (el && !el.contains(e.target)) el.classList.remove('active');
    });
</script>
