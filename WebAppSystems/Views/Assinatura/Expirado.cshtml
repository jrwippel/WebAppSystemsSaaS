@{
    ViewData["Title"] = "Assinatura Expirada";
    Layout = null;
    bool isTrialExpired = ViewBag.IsTrialExpired == true;
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Assinatura Expirada — Time Tracker</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap-flaty.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
        .card { background: white; border-radius: 20px; padding: 48px 40px; max-width: 520px; width: 100%; box-shadow: 0 20px 60px rgba(0,0,0,0.2); text-align: center; }
        .icon-wrap { width: 80px; height: 80px; background: linear-gradient(135deg, #667eea, #764ba2); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px; }
        .icon-wrap i { font-size: 36px; color: white; }
        h1 { font-size: 26px; font-weight: 700; color: #2d3748; margin-bottom: 8px; }
        .subtitle { color: #667eea; font-size: 15px; font-weight: 600; margin-bottom: 16px; }
        p { color: #718096; font-size: 14px; line-height: 1.7; margin-bottom: 0; }
        .contact-box { background: #f7f8fc; border-radius: 12px; padding: 20px; margin: 28px 0; border: 1px solid #e2e8f0; }
        .contact-box p { margin: 0; font-size: 13px; color: #4a5568; }
        .contact-box a { color: #667eea; font-weight: 600; text-decoration: none; }
        .btn-logout { display: inline-flex; align-items: center; gap: 8px; padding: 12px 28px; background: linear-gradient(135deg, #667eea, #764ba2); color: white; border: none; border-radius: 10px; font-size: 14px; font-weight: 600; cursor: pointer; text-decoration: none; transition: all 0.2s; }
        .btn-logout:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(102,126,234,0.4); color: white; }
        .days-badge { display: inline-block; background: #fff3cd; color: #856404; border: 1px solid #ffc107; border-radius: 20px; padding: 4px 14px; font-size: 12px; font-weight: 600; margin-bottom: 20px; }
    </style>
</head>
<body>
    <div class="card">
        <div class="icon-wrap">
            <i class="bi bi-lock-fill"></i>
        </div>

        @if (isTrialExpired)
        {
            <span class="days-badge"><i class="bi bi-clock"></i> Período de teste encerrado</span>
            <h1>Seu trial expirou</h1>
            <p class="subtitle">@ViewBag.TenantName</p>
            <p>O período de teste gratuito de 14 dias chegou ao fim. Para continuar usando o Time Tracker, entre em contato para assinar um plano.</p>
        }
        else
        {
            <h1>Conta suspensa</h1>
            <p class="subtitle">@ViewBag.TenantName</p>
            <p>O acesso à sua conta foi suspenso. Entre em contato com o suporte para regularizar sua situação.</p>
        }

        <div class="contact-box">
            <p><i class="bi bi-envelope"></i> Para assinar ou reativar sua conta, entre em contato:</p>
            <p style="margin-top:8px;"><a href="mailto:jrwsolucoesti@hotmail.com">jrwsolucoesti@hotmail.com</a></p>
            <p style="margin-top:6px;"><i class="bi bi-whatsapp"></i> <a href="https://wa.me/5547999346159" target="_blank">+55 47 99934-6159</a></p>
        </div>

        <a href="/Login/Sair" class="btn-logout">
            <i class="bi bi-box-arrow-right"></i> Sair
        </a>
    </div>
</body>
</html>
