@model AlterarSenhaModel
@{
    ViewData["Title"] = "Alterar Senha";
}

<div class="password-change-container">
    <!-- Header -->
    <div class="page-header">
        <div class="header-content">
            <div class="header-icon">
                <i class="bi bi-shield-lock"></i>
            </div>
            <div class="header-text">
                <h1 class="page-title" data-i18n="password.title">Alterar Senha</h1>
                <p class="page-subtitle" data-i18n="password.subtitle">Atualize sua senha de acesso</p>
            </div>
        </div>
    </div>

    <!-- Form Card -->
    <div class="form-card">
        @if (TempData["MensagemSucesso"] != null)
        {
            <div class="alert alert-success">
                <i class="bi bi-check-circle"></i>
                @TempData["MensagemSucesso"]
            </div>
        }

        @if (TempData["MensagemErro"] != null)
        {
            <div class="alert alert-danger">
                <i class="bi bi-exclamation-circle"></i>
                @TempData["MensagemErro"]
            </div>
        }

        @if (TempData["MensagemAviso"] != null)
        {
            <div class="alert alert-warning">
                <i class="bi bi-exclamation-triangle"></i>
                @TempData["MensagemAviso"]
            </div>
        }

        <form asp-controller="AlterarSenha" asp-action="Alterar" method="post">
            <div class="form-section">
                <div class="form-group">
                    <label asp-for="SenhaAtual" class="form-label">
                        <i class="bi bi-lock"></i>
                        <span data-i18n="password.current">Senha Atual</span>
                    </label>
                    <input type="password" asp-for="SenhaAtual" class="modern-input" placeholder="Digite sua senha atual" />
                    <span asp-validation-for="SenhaAtual" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="SenhaNova" class="form-label">
                        <i class="bi bi-key"></i>
                        <span data-i18n="password.new">Nova Senha</span>
                    </label>
                    <input type="password" asp-for="SenhaNova" class="modern-input" placeholder="Digite a nova senha" />
                    <span asp-validation-for="SenhaNova" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmarNovaSenha" class="form-label">
                        <i class="bi bi-check2-circle"></i>
                        <span data-i18n="password.confirm">Confirmar Nova Senha</span>
                    </label>
                    <input type="password" asp-for="ConfirmarNovaSenha" class="modern-input" placeholder="Confirme a nova senha" />
                    <span asp-validation-for="ConfirmarNovaSenha" class="field-error"></span>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="form-actions">
                <button type="submit" class="btn btn-save">
                    <i class="bi bi-check-circle"></i>
                    <span data-i18n="common.save">Salvar</span>
                </button>
                <a asp-controller="Home" asp-action="Index" class="btn btn-cancel">
                    <i class="bi bi-x-circle"></i>
                    <span data-i18n="common.cancel">Cancelar</span>
                </a>
            </div>
        </form>
    </div>
</div>

<style>
    .password-change-container {
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
    }

    /* Page Header */
    .page-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 12px;
        padding: 24px 28px;
        margin-bottom: 24px;
        box-shadow: 0 6px 25px rgba(102, 126, 234, 0.25);
        animation: slideDown 0.5s ease;
    }

    .header-content {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .header-icon {
        width: 50px;
        height: 50px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: white;
        backdrop-filter: blur(10px);
        flex-shrink: 0;
    }

    .header-text {
        flex: 1;
    }

    .page-title {
        font-size: 24px;
        font-weight: 700;
        color: white;
        margin: 0 0 6px 0;
        letter-spacing: -0.5px;
    }

    .page-subtitle {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.9);
        margin: 0;
    }

    /* Form Card */
    .form-card {
        background: white;
        border-radius: 12px;
        padding: 30px;
        box-shadow: 0 2px 15px rgba(0, 0, 0, 0.05);
        animation: fadeInUp 0.6s ease;
    }

    /* Form Section */
    .form-section {
        margin-bottom: 20px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        font-weight: 600;
        color: #4a5568;
        margin-bottom: 8px;
    }

    .form-label i {
        font-size: 16px;
        color: #667eea;
    }

    .modern-input {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        font-size: 14px;
        color: #2d3748;
        transition: all 0.3s ease;
        background: white;
    }

    .modern-input:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    .field-error {
        display: block;
        color: #f56565;
        font-size: 12px;
        margin-top: 6px;
        font-weight: 500;
    }

    /* Alerts */
    .alert {
        border-radius: 8px;
        border: none;
        padding: 14px 18px;
        margin-bottom: 20px;
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .alert i {
        font-size: 18px;
    }

    .alert-success {
        background: #f0fff4;
        color: #22543d;
        border-left: 4px solid #48bb78;
    }

    .alert-danger {
        background: #fff5f5;
        color: #c53030;
        border-left: 4px solid #f56565;
    }

    .alert-warning {
        background: #fffbeb;
        color: #744210;
        border-left: 4px solid #f6ad55;
    }

    /* Form Actions */
    .form-actions {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #e2e8f0;
    }

    .btn {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 28px;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .btn-save {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
    }

    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
        color: white;
    }

    .btn-cancel {
        background: white;
        color: #4a5568;
        border: 2px solid #e2e8f0;
    }

    .btn-cancel:hover {
        background: #f7fafc;
        border-color: #cbd5e0;
        transform: translateY(-2px);
        color: #2d3748;
    }

    /* Animations */
    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .password-change-container {
            padding: 12px;
        }

        .page-header {
            padding: 18px 20px;
        }

        .form-card {
            padding: 20px;
        }

        .form-actions {
            flex-direction: column-reverse;
        }

        .btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
