@model ClockTrack.Models.Mensalista

@{
    ViewData["Title"] = "Excluir Mensalista";
}

<div class="delete-container">
    <!-- Header -->
    <div class="page-header">
        <div class="header-content">
            <div class="header-icon">
                <i class="bi bi-exclamation-triangle"></i>
            </div>
            <div class="header-text">
                <h1 class="page-title">Confirmar Exclusão</h1>
                <p class="page-subtitle">Esta ação não pode ser desfeita</p>
            </div>
        </div>
    </div>

    <!-- Warning Card -->
    <div class="warning-card">
        <div class="warning-icon">
            <i class="bi bi-shield-exclamation"></i>
        </div>
        <div class="warning-content">
            <h3>Você tem certeza que deseja excluir este mensalista?</h3>
            <p>Todos os dados do contrato mensal serão permanentemente removidos do sistema.</p>
        </div>
    </div>

    <!-- Mensalista Info Card -->
    <div class="mensalista-info-card">
        <div class="mensalista-header">
            <div class="client-icon">
                <i class="bi bi-person-circle"></i>
            </div>
            <div class="client-details">
                <h2>@Model.Client.Name</h2>
                <p>Cliente Mensalista</p>
            </div>
        </div>

        <div class="values-section">
            <div class="value-item primary">
                <i class="bi bi-cash-stack"></i>
                <div>
                    <label>Valor Mensal Bruto</label>
                    <span>@String.Format(new System.Globalization.CultureInfo("pt-BR"), "{0:C2}", Model.ValorMensalBruto)</span>
                </div>
            </div>

            <div class="value-item success">
                <i class="bi bi-person-check"></i>
                <div>
                    <label>Comissão Parceiro</label>
                    <span>@String.Format(new System.Globalization.CultureInfo("pt-BR"), "{0:C2}", Model.ComissaoParceiro)</span>
                </div>
            </div>

            <div class="value-item info">
                <i class="bi bi-briefcase"></i>
                <div>
                    <label>Comissão Sócio</label>
                    <span>@String.Format(new System.Globalization.CultureInfo("pt-BR"), "{0:C2}", Model.ComissaoSocio)</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="actions-card">
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="action-buttons">
                <button type="submit" class="btn-delete">
                    <i class="bi bi-trash"></i>
                    Confirmar Exclusão
                </button>
                <a asp-action="Index" class="btn-cancel">
                    <i class="bi bi-arrow-left"></i>
                    Cancelar e Voltar
                </a>
            </div>
        </form>
    </div>
</div>

<style>
    .delete-container {
        max-width: 700px;
        margin: 0 auto;
        padding: 20px;
    }

    .page-header {
        background: linear-gradient(135deg, #e53e3e 0%, #c53030 100%);
        border-radius: 12px;
        padding: 24px 28px;
        margin-bottom: 24px;
        box-shadow: 0 6px 25px rgba(229, 62, 62, 0.25);
    }

    .header-content {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .header-icon {
        width: 50px;
        height: 50px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: white;
        backdrop-filter: blur(10px);
        animation: pulse 2s ease-in-out infinite;
    }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1);
        }
        50% {
            transform: scale(1.05);
        }
    }

    .page-title {
        font-size: 24px;
        font-weight: 700;
        color: white;
        margin: 0 0 6px 0;
    }

    .page-subtitle {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.9);
        margin: 0;
    }

    .warning-card {
        background: #fff5f5;
        border: 2px solid #feb2b2;
        border-radius: 12px;
        padding: 24px;
        margin-bottom: 24px;
        display: flex;
        gap: 20px;
        align-items: flex-start;
    }

    .warning-icon {
        width: 48px;
        height: 48px;
        background: #e53e3e;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: white;
        flex-shrink: 0;
    }

    .warning-content h3 {
        font-size: 18px;
        font-weight: 600;
        color: #c53030;
        margin: 0 0 8px 0;
    }

    .warning-content p {
        font-size: 14px;
        color: #742a2a;
        margin: 0;
        line-height: 1.6;
    }

    .mensalista-info-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 15px rgba(0, 0, 0, 0.05);
        overflow: hidden;
        margin-bottom: 24px;
    }

    .mensalista-header {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 24px;
        background: linear-gradient(135deg, rgba(229, 62, 62, 0.05) 0%, rgba(197, 48, 48, 0.05) 100%);
        border-bottom: 2px solid #e2e8f0;
    }

    .client-icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: linear-gradient(135deg, #e53e3e 0%, #c53030 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 4px 15px rgba(229, 62, 62, 0.3);
    }

    .client-icon i {
        font-size: 32px;
        color: white;
    }

    .client-details h2 {
        font-size: 20px;
        font-weight: 700;
        color: #2d3748;
        margin: 0 0 4px 0;
    }

    .client-details p {
        font-size: 14px;
        color: #718096;
        margin: 0;
    }

    .values-section {
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .value-item {
        display: flex;
        gap: 12px;
        align-items: flex-start;
        padding: 16px;
        border-radius: 8px;
    }

    .value-item.primary {
        background: #e6f2ff;
    }

    .value-item.success {
        background: #f0fdf4;
    }

    .value-item.info {
        background: #eff6ff;
    }

    .value-item i {
        font-size: 24px;
        flex-shrink: 0;
        margin-top: 2px;
    }

    .value-item.primary i {
        color: #0066cc;
    }

    .value-item.success i {
        color: #22543d;
    }

    .value-item.info i {
        color: #2c5282;
    }

    .value-item div {
        display: flex;
        flex-direction: column;
        gap: 4px;
        flex: 1;
    }

    .value-item label {
        font-size: 12px;
        font-weight: 600;
        color: #718096;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .value-item span {
        font-size: 18px;
        font-weight: 700;
        color: #2d3748;
    }

    .actions-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 15px rgba(0, 0, 0, 0.05);
        padding: 24px;
    }

    .action-buttons {
        display: flex;
        gap: 12px;
    }

    .btn-delete {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px 24px;
        background: linear-gradient(135deg, #e53e3e 0%, #c53030 100%);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-delete:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(229, 62, 62, 0.4);
    }

    .btn-delete i {
        font-size: 18px;
    }

    .btn-cancel {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px 24px;
        background: #f7fafc;
        color: #4a5568;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .btn-cancel:hover {
        background: #e2e8f0;
        color: #2d3748;
    }

    .btn-cancel i {
        font-size: 18px;
    }

    @@media (max-width: 768px) {
        .delete-container {
            padding: 12px;
        }

        .warning-card {
            flex-direction: column;
        }

        .mensalista-header {
            flex-direction: column;
            text-align: center;
        }

        .action-buttons {
            flex-direction: column-reverse;
        }
    }
</style>
