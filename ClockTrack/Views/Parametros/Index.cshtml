@model IEnumerable<ClockTrack.Models.Parametros>

@{
    ViewData["Title"] = "Configurações";
    bool canCreate = ViewBag.CanCreate;
}

<div class="cfg-index-wrap">

    <div class="cfg-page-header">
        <div style="display:flex;align-items:center;gap:14px">
            <i class="bi bi-gear-fill" style="font-size:26px;color:rgba(255,255,255,.85)"></i>
            <div>
                <h1>Configurações</h1>
                <p>Gerencie logo, aparência e parâmetros financeiros</p>
            </div>
        </div>
        @if (canCreate)
        {
            <a asp-action="Create" class="btn-header-action">
                <i class="bi bi-plus-lg"></i> Nova configuração
            </a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="bi bi-gear"></i>
            <p>Nenhuma configuração cadastrada.</p>
            @if (canCreate)
            {
                <a asp-action="Create" class="btn-header-action" style="margin-top:12px">
                    <i class="bi bi-plus-lg"></i> Criar configuração
                </a>
            }
        </div>
    }

    @foreach (var item in Model)
    {
        <div class="cfg-cards-row">

            <!-- Card: Logo & Aparência -->
            <div class="cfg-card">
                <div class="cfg-card-header">
                    <i class="bi bi-image"></i>
                    <span>Logo & Aparência</span>
                </div>
                <div class="cfg-card-body">
                    <div class="logo-preview">
                        @if (item.LogoData != null)
                        {
                            <img src="/Parametros/Logo/@item.Id"
                                 alt="Logo"
                                 style="max-width:@(item.Width)px;max-height:@(item.Height)px" />
                        }
                        else
                        {
                            <div class="no-logo"><i class="bi bi-image"></i><span>Sem logo</span></div>
                        }
                    </div>
                    <div class="cfg-info-row">
                        <span><i class="bi bi-arrows-expand"></i> Dimensões</span>
                        <strong>@item.Width × @item.Height px</strong>
                    </div>
                </div>
                <div class="cfg-card-footer">
                    <a asp-action="EditLogo" asp-route-id="@item.Id" class="btn-card-action btn-edit">
                        <i class="bi bi-pencil"></i> Editar
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn-card-action btn-delete">
                        <i class="bi bi-trash"></i> Excluir
                    </a>
                </div>
            </div>

            <!-- Card: Financeiro -->
            <div class="cfg-card">
                <div class="cfg-card-header">
                    <i class="bi bi-percent"></i>
                    <span>Financeiro</span>
                </div>
                <div class="cfg-card-body">
                    <div class="kpi-block">
                        <span class="kpi-label">Alíquota de Tributos</span>
                        <span class="kpi-value">@item.AliquotaTributos.ToString("0.00")%</span>
                        <span class="kpi-hint">Aplicada sobre mensalidades e horas técnicas</span>
                    </div>
                </div>
                <div class="cfg-card-footer">
                    <a asp-action="EditFinanceiro" asp-route-id="@item.Id" class="btn-card-action btn-edit">
                        <i class="bi bi-pencil"></i> Editar
                    </a>
                </div>
            </div>

        </div>
    }
</div>

<style>
    .cfg-index-wrap { max-width: 860px; margin: 0 auto; padding: 24px 16px; }

    .cfg-page-header {
        display: flex; justify-content: space-between; align-items: center;
        background: linear-gradient(135deg, #667eea, #764ba2);
        border-radius: 12px; padding: 20px 24px; margin-bottom: 28px;
        box-shadow: 0 4px 20px rgba(102,126,234,.25);
    }
    .cfg-page-header h1 { font-size: 20px; font-weight: 700; color: #fff; margin: 0 0 2px; }
    .cfg-page-header p  { font-size: 13px; color: rgba(255,255,255,.8); margin: 0; }

    .btn-header-action {
        display: flex; align-items: center; gap: 6px; padding: 9px 18px;
        background: #fff; color: #667eea; border-radius: 8px; font-size: 13px;
        font-weight: 600; text-decoration: none; white-space: nowrap;
    }
    .btn-header-action:hover { color: #764ba2; }

    .cfg-cards-row {
        display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;
    }

    .cfg-card {
        background: #fff; border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,.07);
        display: flex; flex-direction: column; overflow: hidden;
    }

    .cfg-card-header {
        display: flex; align-items: center; gap: 8px;
        padding: 14px 20px; border-bottom: 1px solid #e2e8f0;
        font-size: 13px; font-weight: 700; color: #4a5568;
        text-transform: uppercase; letter-spacing: .4px;
    }
    .cfg-card-header i { color: #667eea; font-size: 15px; }

    .cfg-card-body { padding: 20px; flex: 1; }

    .logo-preview {
        display: flex; align-items: center; justify-content: center;
        background: #f7fafc; border-radius: 8px; padding: 20px;
        min-height: 100px; margin-bottom: 16px;
    }
    .logo-preview img { max-width: 100%; height: auto; object-fit: contain; }
    .no-logo { display: flex; flex-direction: column; align-items: center; gap: 6px; color: #a0aec0; }
    .no-logo i { font-size: 32px; }
    .no-logo span { font-size: 12px; }

    .cfg-info-row {
        display: flex; justify-content: space-between; align-items: center;
        padding: 9px 12px; background: #f7fafc; border-radius: 7px;
        font-size: 13px; color: #4a5568;
    }
    .cfg-info-row i { color: #667eea; margin-right: 5px; }
    .cfg-info-row strong { color: #2d3748; }

    .kpi-block {
        display: flex; flex-direction: column; align-items: center;
        justify-content: center; padding: 24px 0; gap: 6px;
    }
    .kpi-label { font-size: 12px; font-weight: 600; color: #718096; text-transform: uppercase; letter-spacing: .4px; }
    .kpi-value { font-size: 36px; font-weight: 800; color: #667eea; line-height: 1; }
    .kpi-hint  { font-size: 11px; color: #a0aec0; text-align: center; }

    .cfg-card-footer {
        display: flex; gap: 8px; padding: 14px 20px;
        border-top: 1px solid #e2e8f0; background: #f7fafc;
    }
    .btn-card-action {
        display: flex; align-items: center; gap: 6px; padding: 7px 14px;
        border-radius: 7px; font-size: 13px; font-weight: 600; text-decoration: none;
        transition: opacity .15s;
    }
    .btn-card-action:hover { opacity: .85; }
    .btn-edit   { background: #667eea; color: #fff; }
    .btn-delete { background: #fff; color: #e53e3e; border: 1.5px solid #fed7d7; }
    .btn-delete:hover { background: #fff5f5; }

    .empty-state {
        text-align: center; padding: 60px 20px; background: #fff;
        border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,.07);
    }
    .empty-state i { font-size: 56px; color: #cbd5e0; display: block; margin-bottom: 12px; }
    .empty-state p { color: #718096; font-size: 14px; }

    @@media (max-width: 600px) {
        .cfg-cards-row { grid-template-columns: 1fr; }
        .cfg-page-header { flex-direction: column; gap: 12px; align-items: flex-start; }
    }
</style>
