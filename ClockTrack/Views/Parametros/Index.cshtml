@model IEnumerable<ClockTrack.Models.Parametros>

@{
    ViewData["Title"] = "Configurações";
    bool canCreate = ViewBag.CanCreate;
}

<div class="settings-container">
    <!-- Header -->
    <div class="page-header">
        <div class="header-content">
            <div class="header-icon">
                <i class="bi bi-gear"></i>
            </div>
            <div class="header-text">
                <h1 class="page-title" data-i18n="settings.title">Configurações</h1>
                <p class="page-subtitle" data-i18n="settings.subtitle">Gerencie as configurações do sistema</p>
            </div>
        </div>
        @if (canCreate)
        {
            <a asp-action="Create" class="btn-new">
                <i class="bi bi-plus-circle"></i>
                <span data-i18n="common.new">Novo</span>
            </a>
        }
    </div>

    <!-- Settings Card -->
    <div class="settings-card">
        @if (Model.Any())
        {
            <div class="settings-grid">
                @foreach (var item in Model)
                {
                    <div class="setting-item">
                        <div class="setting-logo">
                            @if (item.LogoData != null && item.LogoMimeType != null)
                            {
                                var base64Image = Convert.ToBase64String(item.LogoData);
                                var imgSrc = $"data:{item.LogoMimeType};base64,{base64Image}";
                                <img src="@imgSrc" alt="Logo" />
                            }
                            else
                            {
                                <div class="no-logo">
                                    <i class="bi bi-image"></i>
                                    <span data-i18n="settings.noimage">Sem imagem</span>
                                </div>
                            }
                        </div>
                        
                        <div class="setting-info">
                            <div class="info-row">
                                <span class="info-label">
                                    <i class="bi bi-arrows-expand"></i>
                                    <span data-i18n="settings.dimensions">Dimensões:</span>
                                </span>
                                <span class="info-value">@item.Width x @item.Height px</span>
                            </div>
                        </div>
                        
                        <div class="setting-actions">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action btn-edit" title="Editar">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn-action btn-details" title="Detalhes">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action btn-delete" title="Excluir">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-gear"></i>
                <h3 data-i18n="settings.empty">Nenhuma configuração encontrada</h3>
                <p data-i18n="settings.empty.desc">Adicione uma nova configuração para começar</p>
                @if (canCreate)
                {
                    <a asp-action="Create" class="btn-new">
                        <i class="bi bi-plus-circle"></i>
                        <span data-i18n="common.new">Novo</span>
                    </a>
                }
            </div>
        }
    </div>
</div>

<style>
    .settings-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
    }

    /* Page Header */
    .page-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 12px;
        padding: 24px 28px;
        margin-bottom: 24px;
        box-shadow: 0 6px 25px rgba(102, 126, 234, 0.25);
        display: flex;
        align-items: center;
        justify-content: space-between;
        animation: slideDown 0.5s ease;
    }

    .header-content {
        display: flex;
        align-items: center;
        gap: 16px;
        flex: 1;
    }

    .header-icon {
        width: 50px;
        height: 50px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: white;
        backdrop-filter: blur(10px);
    }

    .page-title {
        font-size: 24px;
        font-weight: 700;
        color: white;
        margin: 0 0 6px 0;
    }

    .page-subtitle {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.9);
        margin: 0;
    }

    .btn-new {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: white;
        color: #667eea;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .btn-new:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(255, 255, 255, 0.3);
        color: #667eea;
    }

    /* Settings Card */
    .settings-card {
        background: white;
        border-radius: 12px;
        padding: 30px;
        box-shadow: 0 2px 15px rgba(0, 0, 0, 0.05);
        animation: fadeInUp 0.6s ease;
    }

    /* Settings Grid */
    .settings-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 24px;
    }

    .setting-item {
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        padding: 20px;
        transition: all 0.3s ease;
    }

    .setting-item:hover {
        border-color: #667eea;
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.15);
        transform: translateY(-2px);
    }

    .setting-logo {
        width: 100%;
        height: 150px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f7fafc;
        border-radius: 8px;
        margin-bottom: 16px;
        overflow: hidden;
    }

    .setting-logo img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
    }

    .no-logo {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        color: #a0aec0;
    }

    .no-logo i {
        font-size: 40px;
    }

    .setting-info {
        margin-bottom: 16px;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px;
        background: #f7fafc;
        border-radius: 6px;
    }

    .info-label {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        font-weight: 600;
        color: #4a5568;
    }

    .info-label i {
        color: #667eea;
    }

    .info-value {
        font-size: 13px;
        font-weight: 600;
        color: #2d3748;
    }

    .setting-actions {
        display: flex;
        gap: 8px;
        justify-content: center;
        padding-top: 16px;
        border-top: 1px solid #e2e8f0;
    }

    .btn-action {
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
    }

    .btn-edit {
        background: #3182ce;
        color: white;
    }

    .btn-edit:hover {
        background: #2c5aa0;
        transform: scale(1.1);
    }

    .btn-details {
        background: #38a169;
        color: white;
    }

    .btn-details:hover {
        background: #2f855a;
        transform: scale(1.1);
    }

    .btn-delete {
        background: #e53e3e;
        color: white;
    }

    .btn-delete:hover {
        background: #c53030;
        transform: scale(1.1);
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 60px 20px;
    }

    .empty-state i {
        font-size: 80px;
        color: #cbd5e0;
        margin-bottom: 20px;
    }

    .empty-state h3 {
        font-size: 20px;
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 8px;
    }

    .empty-state p {
        font-size: 14px;
        color: #718096;
        margin-bottom: 24px;
    }

    /* Animations */
    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .settings-container {
            padding: 12px;
        }

        .page-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 16px;
        }

        .btn-new {
            width: 100%;
            justify-content: center;
        }

        .settings-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
