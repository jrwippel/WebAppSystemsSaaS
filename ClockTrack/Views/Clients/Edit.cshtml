@model ClockTrack.Models.Client

@{
    ViewData["Title"] = "Editar Cliente";
}

<div class="edit-container">
    <!-- Header -->
    <div class="page-header">
        <div class="header-content">
            <div class="header-left">
                <div class="header-icon">
                    <i class="bi bi-pencil-square"></i>
                </div>
                <div class="header-text">
                    <h1 class="page-title">Editar Cliente</h1>
                    <p class="page-subtitle">Atualize as informações do cliente</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Form Card -->
    <div class="form-card">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <!-- Image Section -->
            <div class="image-section">
                <div class="current-image">
                    @if (Model.ImageData != null && !string.IsNullOrEmpty(Model.ImageMimeType))
                    {
                        var imageBase64 = Convert.ToBase64String(Model.ImageData);
                        var imageSrc = $"data:{Model.ImageMimeType};base64,{imageBase64}";
                        <img src="@imageSrc" alt="@Model.Name" id="imagePreview" />
                    }
                    else
                    {
                        <div class="image-placeholder" id="imagePreview">
                            <i class="bi bi-person-fill"></i>
                        </div>
                    }
                </div>
                <div class="image-upload">
                    <label for="imageInput" class="upload-label">
                        <i class="bi bi-cloud-upload"></i>
                        <span>Alterar Imagem</span>
                    </label>
                    <input type="file" id="imageInput" name="imageData" class="file-input" accept="image/*" />
                    <p class="upload-hint">PNG, JPG ou GIF (máx. 5MB)</p>
                </div>
            </div>

            <!-- Basic Info Section -->
            <div class="form-section">
                <h3 class="section-title">
                    <i class="bi bi-person"></i>
                    Informações Básicas
                </h3>
                
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Name">
                            <i class="bi bi-person-circle"></i>
                            Nome
                        </label>
                        <input asp-for="Name" class="form-control" placeholder="Nome completo" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Document">
                            <i class="bi bi-card-text"></i>
                            Documento
                        </label>
                        <input asp-for="Document" class="form-control" placeholder="CPF/CNPJ" />
                        <span asp-validation-for="Document" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <!-- Contact Section -->
            <div class="form-section">
                <h3 class="section-title">
                    <i class="bi bi-telephone"></i>
                    Contato
                </h3>
                
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Email">
                            <i class="bi bi-envelope"></i>
                            Email
                        </label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="email@exemplo.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Telephone">
                            <i class="bi bi-telephone"></i>
                            Telefone
                        </label>
                        <input asp-for="Telephone" class="form-control" placeholder="(00) 00000-0000" />
                        <span asp-validation-for="Telephone" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <!-- Additional Info Section -->
            <div class="form-section">
                <h3 class="section-title">
                    <i class="bi bi-info-circle"></i>
                    Informações Adicionais
                </h3>
                
                <div class="form-group">
                    <label asp-for="Solicitante">
                        <i class="bi bi-person-badge"></i>
                        Solicitante
                    </label>
                    <input asp-for="Solicitante" class="form-control" placeholder="Nome do solicitante" />
                    <span asp-validation-for="Solicitante" class="text-danger"></span>
                </div>

                <div class="checkbox-group">
                    <label class="checkbox-card">
                        <input type="checkbox" asp-for="ClienteInterno" />
                        <div class="checkbox-content">
                            <i class="bi bi-building"></i>
                            <div>
                                <strong>Cliente Interno</strong>
                                <span>Marque se for cliente interno da empresa</span>
                            </div>
                        </div>
                        <div class="checkbox-indicator"></div>
                    </label>

                    <label class="checkbox-card">
                        <input type="checkbox" asp-for="ClienteInativo" />
                        <div class="checkbox-content">
                            <i class="bi bi-x-circle"></i>
                            <div>
                                <strong>Cliente Inativo</strong>
                                <span>Marque para desativar este cliente</span>
                            </div>
                        </div>
                        <div class="checkbox-indicator"></div>
                    </label>
                </div>
            </div>

            <!-- Actions -->
            <div class="form-actions">
                <button type="submit" class="btn-submit">
                    <i class="bi bi-check-circle"></i>
                    Salvar Alterações
                </button>
                <a asp-action="Index" class="btn-cancel">
                    <i class="bi bi-x-circle"></i>
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.getElementById('imageInput').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const preview = document.getElementById('imagePreview');
                    preview.innerHTML = '<img src="' + e.target.result + '" alt="Preview" />';
                }
                reader.readAsDataURL(file);
            }
        });
    </script>
}

<style>
    .edit-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 20px;
    }

    .page-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 12px;
        padding: 24px 28px;
        margin-bottom: 24px;
        box-shadow: 0 6px 25px rgba(102, 126, 234, 0.25);
    }

    .header-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
    }

    .header-left {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .header-icon {
        width: 50px;
        height: 50px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: white;
        backdrop-filter: blur(10px);
    }

    .page-title {
        font-size: 24px;
        font-weight: 700;
        color: white;
        margin: 0 0 6px 0;
    }

    .page-subtitle {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.9);
        margin: 0;
    }

    .form-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 15px rgba(0, 0, 0, 0.05);
        padding: 32px;
        overflow: visible;
    }

    .alert-danger {
        background: #fff5f5;
        border: 2px solid #feb2b2;
        border-radius: 8px;
        padding: 16px;
        margin-bottom: 24px;
        color: #c53030;
    }

    .image-section {
        display: flex;
        align-items: center;
        gap: 32px;
        padding: 24px;
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
        border-radius: 12px;
        margin-bottom: 32px;
    }

    .current-image {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        overflow: hidden;
        flex-shrink: 0;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    }

    .current-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .image-placeholder {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 48px;
    }

    .image-upload {
        flex: 1;
    }

    .upload-label {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 24px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .upload-label:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
    }

    .file-input {
        display: none;
    }

    .upload-hint {
        font-size: 12px;
        color: #718096;
        margin: 8px 0 0 0;
    }

    .form-section {
        margin-bottom: 32px;
        overflow: visible;
    }

    .section-title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 18px;
        font-weight: 700;
        color: #2d3748;
        margin: 0 0 20px 0;
        padding-bottom: 12px;
        border-bottom: 2px solid #e2e8f0;
    }

    .section-title i {
        color: #667eea;
        font-size: 20px;
    }

    .form-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        overflow: visible;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        overflow: visible;
    }

    .form-group label {
        font-size: 14px;
        font-weight: 600;
        color: #4a5568;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .form-group label i {
        color: #667eea;
        font-size: 16px;
    }

    .form-control {
        padding: 12px 16px;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        font-size: 14px;
        transition: all 0.3s ease;
        background: white;
        min-height: 44px;
        line-height: 1.5;
    }

    .form-control:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    .form-control::placeholder {
        color: #cbd5e0;
    }

    .text-danger {
        font-size: 12px;
        color: #e53e3e;
        margin-top: 4px;
    }

    .checkbox-group {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .checkbox-card {
        position: relative;
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 16px 20px;
        background: #f7fafc;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .checkbox-card:hover {
        background: #edf2f7;
        border-color: #cbd5e0;
    }

    .checkbox-card input[type="checkbox"] {
        position: absolute;
        opacity: 0;
        cursor: pointer;
    }

    .checkbox-card input[type="checkbox"]:checked ~ .checkbox-content {
        color: #667eea;
    }

    .checkbox-card input[type="checkbox"]:checked ~ .checkbox-indicator {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-color: transparent;
    }

    .checkbox-card input[type="checkbox"]:checked ~ .checkbox-indicator::after {
        display: block;
    }

    .checkbox-content {
        display: flex;
        align-items: center;
        gap: 12px;
        flex: 1;
        transition: all 0.3s ease;
    }

    .checkbox-content i {
        font-size: 24px;
        color: #a0aec0;
    }

    .checkbox-content strong {
        display: block;
        font-size: 14px;
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 2px;
    }

    .checkbox-content span {
        display: block;
        font-size: 12px;
        color: #718096;
    }

    .checkbox-indicator {
        width: 24px;
        height: 24px;
        border: 2px solid #cbd5e0;
        border-radius: 6px;
        background: white;
        position: relative;
        transition: all 0.3s ease;
        flex-shrink: 0;
    }

    .checkbox-indicator::after {
        content: '✓';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: white;
        font-size: 14px;
        font-weight: bold;
        display: none;
    }

    .form-actions {
        display: flex;
        gap: 12px;
        margin-top: 32px;
        padding-top: 32px;
        border-top: 2px solid #e2e8f0;
    }

    .btn-submit {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px 24px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
    }

    .btn-submit i {
        font-size: 18px;
    }

    .btn-cancel {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px 24px;
        background: #f7fafc;
        color: #4a5568;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .btn-cancel:hover {
        background: #e2e8f0;
        color: #2d3748;
    }

    .btn-cancel i {
        font-size: 18px;
    }

    @@media (max-width: 768px) {
        .edit-container {
            padding: 12px;
        }

        .form-card {
            padding: 20px;
        }

        .image-section {
            flex-direction: column;
            text-align: center;
        }

        .form-row {
            grid-template-columns: 1fr;
        }

        .form-actions {
            flex-direction: column;
        }
    }
</style>
