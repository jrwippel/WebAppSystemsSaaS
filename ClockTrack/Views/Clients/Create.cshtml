@using ClockTrack.Models.Enums;
@model ClockTrack.Models.Client
@{
    ViewData["Title"] = "Novo Cliente";
}

<div class="create-container">
    <!-- Header -->
    <div class="page-header">
        <div class="header-content">
            <div class="header-left">
                <div class="header-icon">
                    <i class="bi bi-plus-circle"></i>
                </div>
                <div class="header-text">
                    <h1 class="page-title">Novo Cliente</h1>
                    <p class="page-subtitle">Cadastre um novo cliente no sistema</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Form Card -->
    <div class="form-card">
        <form asp-action="Create" method="post" enctype="multipart/form-data" novalidate>            
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <!-- Informações Básicas -->
            <div class="form-section">
                <h3 class="section-title">
                    <i class="bi bi-info-circle"></i>
                    Informações Básicas
                </h3>
                
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Name">
                            <i class="bi bi-building"></i>
                            Nome
                        </label>
                        <input asp-for="Name" class="form-control" placeholder="Digite o nome do cliente" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Document">
                            <i class="bi bi-file-text"></i>
                            Documento
                        </label>
                        <input asp-for="Document" class="form-control" placeholder="CPF/CNPJ" data-val="false" />
                        <span asp-validation-for="Document" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Email">
                            <i class="bi bi-envelope"></i>
                            Email
                        </label>
                        <input asp-for="Email" class="form-control" placeholder="email@exemplo.com" data-val="false" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Telephone">
                            <i class="bi bi-telephone"></i>
                            Telefone
                        </label>
                        <input asp-for="Telephone" class="form-control" placeholder="(00) 00000-0000" data-val="false" />
                        <span asp-validation-for="Telephone" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Solicitante">
                            <i class="bi bi-person-check"></i>
                            Solicitante Padrão
                        </label>
                        <input asp-for="Solicitante" class="form-control" placeholder="Nome do solicitante padrão" />   
                    </div>
                </div>
            </div>

            <!-- Logo -->
            <div class="form-section">
                <h3 class="section-title">
                    <i class="bi bi-image"></i>
                    Logo do Cliente
                </h3>
                
                <div class="form-group">
                    <label asp-for="ImageData">
                        <i class="bi bi-upload"></i>
                        Arquivo de Imagem
                    </label>
                    <input asp-for="ImageData" name="imageData" type="file" class="form-control" accept="image/*" />
                    <span asp-validation-for="ImageData" class="text-danger"></span>
                    @if (Model != null && Model.ImageData != null && !string.IsNullOrEmpty(Model.ImageMimeType))
                    {
                        var imageBase64 = Convert.ToBase64String(Model.ImageData);
                        var imageSrc = $"data:{Model.ImageMimeType};base64,{imageBase64}";
                        <div class="image-preview">
                            <img src="@imageSrc" alt="Client Image" />
                        </div>
                    }
                </div>
            </div>

            <!-- Preferências -->
            <div class="form-section">
                <h3 class="section-title">
                    <i class="bi bi-gear"></i>
                    Preferências
                </h3>
                
                <div class="preferences-grid">
                    <div class="form-check-card">
                        <input type="checkbox" asp-for="ClienteInterno" class="form-check-input" id="clienteInterno" />
                        <label for="clienteInterno" class="form-check-label">
                            <i class="bi bi-house"></i>
                            <div>
                                <strong>Cliente Interno</strong>
                                <span>Cliente pertence à organização</span>
                            </div>
                        </label>
                    </div>

                    <div class="form-check-card">
                        <input type="checkbox" asp-for="ClienteInativo" class="form-check-input" id="clienteInativo" />
                        <label for="clienteInativo" class="form-check-label">
                            <i class="bi bi-x-circle"></i>
                            <div>
                                <strong>Cliente Inativo</strong>
                                <span>Desativar cliente no sistema</span>
                            </div>
                        </label>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="form-actions">
                <button type="submit" class="btn-submit">
                    <i class="bi bi-check-circle"></i>
                    Salvar
                </button>
                <a asp-action="Index" class="btn-cancel">
                    <i class="bi bi-x-circle"></i>
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<style>
    .create-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 20px;
    }

    .page-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 12px;
        padding: 24px 28px;
        margin-bottom: 24px;
        box-shadow: 0 6px 25px rgba(102, 126, 234, 0.25);
    }

    .header-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
    }

    .header-left {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .header-icon {
        width: 50px;
        height: 50px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: white;
        backdrop-filter: blur(10px);
    }

    .page-title {
        font-size: 24px;
        font-weight: 700;
        color: white;
        margin: 0 0 6px 0;
    }

    .page-subtitle {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.9);
        margin: 0;
    }

    .form-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 15px rgba(0, 0, 0, 0.05);
        padding: 32px;
        overflow: visible;
    }

    .form-section {
        margin-bottom: 32px;
        padding-bottom: 32px;
        border-bottom: 2px solid #e2e8f0;
        overflow: visible;
    }

    .form-section:last-of-type {
        border-bottom: none;
        margin-bottom: 0;
        padding-bottom: 0;
    }

    .section-title {
        font-size: 18px;
        font-weight: 600;
        color: #2d3748;
        margin: 0 0 24px 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .section-title i {
        color: #667eea;
        font-size: 20px;
    }

    .form-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-bottom: 20px;
        overflow: visible;
    }

    .form-row:last-child {
        margin-bottom: 0;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .form-group label {
        font-size: 14px;
        font-weight: 600;
        color: #4a5568;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .form-group label i {
        color: #667eea;
        font-size: 16px;
    }

    .form-control {
        padding: 12px 16px;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        font-size: 14px;
        transition: all 0.3s ease;
        background: white;
        min-height: 44px;
        line-height: 1.5;
    }

    .form-control:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    .form-control::placeholder {
        color: #cbd5e0;
    }

    .text-danger {
        font-size: 12px;
        color: #e53e3e;
        margin-top: 4px;
    }

    .alert-danger {
        background: #fff5f5;
        border: 2px solid #feb2b2;
        border-radius: 8px;
        padding: 16px;
        margin-bottom: 24px;
        color: #c53030;
    }

    .image-preview {
        margin-top: 12px;
        padding: 12px;
        background: #f7fafc;
        border-radius: 8px;
        text-align: center;
    }

    .image-preview img {
        max-width: 200px;
        max-height: 200px;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .preferences-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 16px;
    }

    .form-check-card {
        position: relative;
        background: #f7fafc;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        padding: 16px;
        transition: all 0.3s ease;
    }

    .form-check-card:has(.form-check-input:checked) {
        background: rgba(102, 126, 234, 0.05);
        border-color: #667eea;
    }

    .form-check-input {
        position: absolute;
        top: 16px;
        right: 16px;
        width: 20px;
        height: 20px;
        cursor: pointer;
    }

    .form-check-label {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        cursor: pointer;
        padding-right: 32px;
    }

    .form-check-label i {
        font-size: 24px;
        color: #667eea;
        flex-shrink: 0;
    }

    .form-check-label div {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .form-check-label strong {
        font-size: 14px;
        font-weight: 600;
        color: #2d3748;
    }

    .form-check-label span {
        font-size: 12px;
        color: #718096;
    }

    .form-actions {
        display: flex;
        gap: 12px;
        margin-top: 32px;
        padding-top: 32px;
        border-top: 2px solid #e2e8f0;
    }

    .btn-submit {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px 24px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
    }

    .btn-submit i {
        font-size: 18px;
    }

    .btn-cancel {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px 24px;
        background: #f7fafc;
        color: #4a5568;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .btn-cancel:hover {
        background: #e2e8f0;
        color: #2d3748;
    }

    .btn-cancel i {
        font-size: 18px;
    }

    @@media (max-width: 768px) {
        .create-container {
            padding: 12px;
        }

        .form-card {
            padding: 20px;
        }

        .form-row {
            grid-template-columns: 1fr;
        }

        .preferences-grid {
            grid-template-columns: 1fr;
        }

        .form-actions {
            flex-direction: column;
        }
    }
</style>