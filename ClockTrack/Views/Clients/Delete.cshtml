@model ClockTrack.Models.Client

@{
    ViewData["Title"] = "Excluir Cliente";
}

<div class="delete-container">
    <!-- Header -->
    <div class="page-header">
        <div class="header-content">
            <div class="header-icon">
                <i class="bi bi-exclamation-triangle"></i>
            </div>
            <div class="header-text">
                <h1 class="page-title">Confirmar Exclusão</h1>
                <p class="page-subtitle">Esta ação não pode ser desfeita</p>
            </div>
        </div>
    </div>

    <!-- Warning Card -->
    <div class="warning-card">
        <div class="warning-icon">
            <i class="bi bi-shield-exclamation"></i>
        </div>
        <div class="warning-content">
            <h3>Você tem certeza que deseja excluir este cliente?</h3>
            <p>Todos os dados associados a este cliente serão permanentemente removidos do sistema.</p>
        </div>
    </div>

    <!-- Client Info Card -->
    <div class="client-info-card">
        <div class="client-header">
            <div class="client-avatar">
                @if (Model.ImageData != null && !string.IsNullOrEmpty(Model.ImageMimeType))
                {
                    var imageBase64 = Convert.ToBase64String(Model.ImageData);
                    var imageSrc = $"data:{Model.ImageMimeType};base64,{imageBase64}";
                    <img src="@imageSrc" alt="@Model.Name" />
                }
                else
                {
                    <i class="bi bi-person-fill"></i>
                }
            </div>
            <div class="client-details">
                <h2>@Model.Name</h2>
                <p>@Model.Email</p>
                <div class="status-badges">
                    @if (Model.ClienteInativo)
                    {
                        <span class="badge badge-inactive">Inativo</span>
                    }
                    @if (Model.ClienteInterno)
                    {
                        <span class="badge badge-internal">Interno</span>
                    }
                </div>
            </div>
        </div>

        <div class="info-grid">
            <div class="info-item">
                <i class="bi bi-card-text"></i>
                <div>
                    <label>Documento</label>
                    <span>@Model.Document</span>
                </div>
            </div>

            <div class="info-item">
                <i class="bi bi-telephone"></i>
                <div>
                    <label>Telefone</label>
                    <span>@Model.Telephone</span>
                </div>
            </div>

            <div class="info-item">
                <i class="bi bi-envelope"></i>
                <div>
                    <label>Email</label>
                    <span>@Model.Email</span>
                </div>
            </div>

            <div class="info-item">
                <i class="bi bi-person-badge"></i>
                <div>
                    <label>Solicitante</label>
                    <span>@Model.Solicitante</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="actions-card">
        <form asp-action="Delete">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            <input type="hidden" asp-for="Id" />
            <div class="action-buttons">
                <button type="submit" class="btn-delete">
                    <i class="bi bi-trash"></i>
                    Confirmar Exclusão
                </button>
                <a asp-action="Index" class="btn-cancel">
                    <i class="bi bi-arrow-left"></i>
                    Cancelar e Voltar
                </a>
            </div>
        </form>
    </div>
</div>

<style>
    .delete-container {
        max-width: 700px;
        margin: 0 auto;
        padding: 20px;
    }

    .page-header {
        background: linear-gradient(135deg, #e53e3e 0%, #c53030 100%);
        border-radius: 12px;
        padding: 24px 28px;
        margin-bottom: 24px;
        box-shadow: 0 6px 25px rgba(229, 62, 62, 0.25);
    }

    .header-content {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .header-icon {
        width: 50px;
        height: 50px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: white;
        backdrop-filter: blur(10px);
        animation: pulse 2s ease-in-out infinite;
    }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1);
        }
        50% {
            transform: scale(1.05);
        }
    }

    .page-title {
        font-size: 24px;
        font-weight: 700;
        color: white;
        margin: 0 0 6px 0;
    }

    .page-subtitle {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.9);
        margin: 0;
    }

    .warning-card {
        background: #fff5f5;
        border: 2px solid #feb2b2;
        border-radius: 12px;
        padding: 24px;
        margin-bottom: 24px;
        display: flex;
        gap: 20px;
        align-items: flex-start;
    }

    .warning-icon {
        width: 48px;
        height: 48px;
        background: #e53e3e;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: white;
        flex-shrink: 0;
    }

    .warning-content h3 {
        font-size: 18px;
        font-weight: 600;
        color: #c53030;
        margin: 0 0 8px 0;
    }

    .warning-content p {
        font-size: 14px;
        color: #742a2a;
        margin: 0;
        line-height: 1.6;
    }

    .client-info-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 15px rgba(0, 0, 0, 0.05);
        overflow: hidden;
        margin-bottom: 24px;
    }

    .client-header {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 24px;
        background: linear-gradient(135deg, rgba(229, 62, 62, 0.05) 0%, rgba(197, 48, 48, 0.05) 100%);
        border-bottom: 2px solid #e2e8f0;
    }

    .client-avatar {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        overflow: hidden;
        background: linear-gradient(135deg, #e53e3e 0%, #c53030 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 4px 15px rgba(229, 62, 62, 0.3);
    }

    .client-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .client-avatar i {
        font-size: 40px;
        color: white;
    }

    .client-details h2 {
        font-size: 20px;
        font-weight: 700;
        color: #2d3748;
        margin: 0 0 4px 0;
    }

    .client-details p {
        font-size: 14px;
        color: #718096;
        margin: 0 0 8px 0;
    }

    .status-badges {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 10px;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }

    .badge-inactive {
        background: #fed7d7;
        color: #742a2a;
    }

    .badge-internal {
        background: #bee3f8;
        color: #2c5282;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        padding: 24px;
    }

    .info-item {
        display: flex;
        gap: 12px;
        align-items: flex-start;
    }

    .info-item i {
        font-size: 20px;
        color: #e53e3e;
        flex-shrink: 0;
        margin-top: 2px;
    }

    .info-item div {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .info-item label {
        font-size: 12px;
        font-weight: 600;
        color: #718096;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .info-item span {
        font-size: 14px;
        font-weight: 500;
        color: #2d3748;
    }

    .actions-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 15px rgba(0, 0, 0, 0.05);
        padding: 24px;
    }

    .text-danger {
        background: #fff5f5;
        border: 2px solid #feb2b2;
        border-radius: 8px;
        padding: 12px;
        margin-bottom: 16px;
        color: #c53030;
        font-size: 14px;
    }

    .action-buttons {
        display: flex;
        gap: 12px;
    }

    .btn-delete {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px 24px;
        background: linear-gradient(135deg, #e53e3e 0%, #c53030 100%);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-delete:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(229, 62, 62, 0.4);
    }

    .btn-delete i {
        font-size: 18px;
    }

    .btn-cancel {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px 24px;
        background: #f7fafc;
        color: #4a5568;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .btn-cancel:hover {
        background: #e2e8f0;
        color: #2d3748;
    }

    .btn-cancel i {
        font-size: 18px;
    }

    @@media (max-width: 768px) {
        .delete-container {
            padding: 12px;
        }

        .warning-card {
            flex-direction: column;
        }

        .client-header {
            flex-direction: column;
            text-align: center;
        }

        .status-badges {
            justify-content: center;
        }

        .info-grid {
            grid-template-columns: 1fr;
        }

        .action-buttons {
            flex-direction: column-reverse;
        }
    }
</style>
