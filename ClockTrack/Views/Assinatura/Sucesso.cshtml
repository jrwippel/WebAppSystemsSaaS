@{
    ViewData["Title"] = "Pagamento Confirmado";
}
<div class="text-center py-5">
    <div style="font-size:64px;">✅</div>
    <h2 class="fw-bold mt-3">Pagamento confirmado!</h2>
    <p class="text-muted">Sua assinatura do plano <strong>@ViewBag.Plano</strong> foi ativada com sucesso.</p>
    <a href="@Url.Action("Index", "Home")" class="btn btn-primary mt-3" style="border-radius:10px;padding:12px 32px;">
        Ir para o sistema
