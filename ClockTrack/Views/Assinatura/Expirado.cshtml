@using ClockTrack.Services
@{
    ViewData["Title"] = "Assinatura Expirada";
    Layout = null;
    bool isTrialExpired = ViewBag.IsTrialExpired == true;
    var planos = ViewBag.Planos as Dictionary<string, PlanoInfo>;
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Assinatura Expirada — ClockTrack</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap-flaty.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; padding: 40px 16px; }
        .hero-card { background: white; border-radius: 20px; padding: 40px; max-width: 520px; margin: 0 auto 32px; box-shadow: 0 20px 60px rgba(0,0,0,0.2); text-align: center; }
        .icon-wrap { width: 72px; height: 72px; background: linear-gradient(135deg, #667eea, #764ba2); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; }
        .icon-wrap i { font-size: 32px; color: white; }
        h1 { font-size: 24px; font-weight: 700; color: #2d3748; margin-bottom: 6px; }
        .subtitle { color: #667eea; font-size: 14px; font-weight: 600; margin-bottom: 12px; }
        .days-badge { display: inline-block; background: #fff3cd; color: #856404; border: 1px solid #ffc107; border-radius: 20px; padding: 4px 14px; font-size: 12px; font-weight: 600; margin-bottom: 16px; }
        .btn-logout { display: inline-flex; align-items: center; gap: 8px; padding: 10px 24px; background: #f1f5f9; color: #4a5568; border: none; border-radius: 10px; font-size: 14px; font-weight: 600; cursor: pointer; text-decoration: none; margin-top: 16px; }
        /* planos */
        .planos-wrap { max-width: 900px; margin: 0 auto; }
        .plano-card { background: white; border-radius: 16px; padding: 28px; text-align: center; box-shadow: 0 8px 32px rgba(0,0,0,0.12); position: relative; }
        .plano-card.destaque { border: 2px solid #667eea; }
        .plano-badge { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: linear-gradient(135deg,#667eea,#764ba2); color: white; padding: 3px 16px; border-radius: 20px; font-size: 11px; font-weight: 700; white-space: nowrap; }
        .plano-nome { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: #718096; margin-bottom: 6px; }
        .plano-preco { font-size: 36px; font-weight: 800; color: #2d3748; }
        .plano-preco span { font-size: 14px; font-weight: 400; color: #718096; }
        .plano-desc { font-size: 13px; color: #718096; margin: 8px 0 16px; }
        .btn-assinar { display: block; padding: 11px; border-radius: 10px; font-weight: 700; font-size: 14px; text-decoration: none; border: none; cursor: pointer; width: 100%; }
        .btn-assinar-primary { background: linear-gradient(135deg,#667eea,#764ba2); color: white; }
        .btn-assinar-outline { background: white; color: #667eea; border: 2px solid #667eea; }
        .section-title { color: white; text-align: center; font-size: 22px; font-weight: 700; margin-bottom: 24px; }
    </style>
</head>
<body>
    <!-- Card de aviso -->
    <div class="hero-card">
        <div class="icon-wrap"><i class="bi bi-lock-fill"></i></div>
        @if (isTrialExpired)
        {
            <span class="days-badge"><i class="bi bi-clock"></i> Periodo de teste encerrado</span>
            <h1>Seu trial expirou</h1>
            <p class="subtitle">@ViewBag.TenantName</p>
            <p style="color:#718096;font-size:14px;">Escolha um plano abaixo para continuar usando o ClockTrack.</p>
        }
        else
        {
            <h1>Conta suspensa</h1>
            <p class="subtitle">@ViewBag.TenantName</p>
            <p style="color:#718096;font-size:14px;">Escolha um plano para reativar sua conta.</p>
        }
        <a href="/Login/Sair" class="btn-logout"><i class="bi bi-box-arrow-right"></i> Sair</a>
    </div>

    <!-- Planos -->
    @if (planos != null)
    {
        <p class="section-title">Escolha seu plano</p>
        <div class="planos-wrap">
            <div class="row g-3 justify-content-center">
                @foreach (var kv in planos)
                {
                    var key = kv.Key;
                    var p = kv.Value;
                    var destaque = key == "pro";
                    <div class="col-md-4">
                        <div class="plano-card @(destaque ? "destaque" : "")">
                            @if (destaque) { <div class="plano-badge">Mais popular</div> }
                            <div class="plano-nome">@p.Nome</div>
                            <div class="plano-preco">R$ @p.Preco.ToString("N0")<span>/mes</span></div>
                            <div class="plano-desc">@p.Descricao</div>
                            <form action="/Assinatura/Assinar" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="plano" value="@key" />
                                <button type="submit" class="btn-assinar @(destaque ? "btn-assinar-primary" : "btn-assinar-outline")">
                                    Assinar agora
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</body>
</html>
