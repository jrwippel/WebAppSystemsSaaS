@{
    ViewData["Title"] = "Dashboard do Cliente";
    var mes = ViewBag.Mes as ClockTrack.Models.ViewModels.MensalistaHoursViewModel;
    var media = ViewBag.Media as ClockTrack.Models.ViewModels.MensalistaHoursViewModel;
    var acumulado = ViewBag.Acumulado as ClockTrack.Models.ViewModels.MensalistaHoursViewModel;
    var ptBR = System.Globalization.CultureInfo.GetCultureInfo("pt-BR");

    string Fmt(decimal v) => v.ToString("N2", ptBR);
    string FmtH(double h) { int wh = (int)h; int wm = (int)Math.Round((h - wh) * 60); return $"{wh:D2}:{wm:D2}"; }
    string ResultClass(decimal v) => v >= 0 ? "kpi-positive" : "kpi-negative";
    string StatusLabel(decimal v, decimal area) {
        if (v >= 0) return "";
        double pct = area > 0 ? (double)v / (double)area * 100 : -100;
        return pct < -20 ? "" : "";
    }
    string StatusClass(decimal v, decimal area) {
        if (v >= 0) return "status-ok";
        double pct = area > 0 ? (double)v / (double)area * 100 : -100;
        return pct < -20 ? "status-danger" : "status-warn";
    }
}

<div class="dash-container">

    <!-- Header -->
    <div class="dash-header">
        <div class="dash-header-left">
            <div class="dash-header-icon"><i class="bi bi-graph-up-arrow"></i></div>
            <div>
                <h1>@mes.Mensalista.Client.Name</h1>
                <p>@ViewData["inputMonthYear"] &nbsp;·&nbsp; @ViewData["departmentName"] &nbsp;·&nbsp; @(mes.Percentual.ToString("0"))%</p>
            </div>
        </div>
        <a href="@Url.Action("SimpleSearch", "Mensalista", new { monthYearString = ViewData["inputMonthYear"]?.ToString()?.Replace("/",""), clientId = ViewData["clientId"], departmentId = ViewData["departmentId"] })" class="btn-back">
            <i class="bi bi-arrow-left"></i> Voltar
        </a>
    </div>

    <!-- KPI Cards (mês atual) -->
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-label"><i class="bi bi-cash-stack"></i> Receita Área Líq.</div>
            <div class="kpi-value">@Fmt(mes.ValorAreaLiquido)</div>
            <div class="kpi-sub">Mensalidade @Fmt(mes.Mensalista.ValorMensalBruto) × @mes.Percentual.ToString("0")%</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label"><i class="bi bi-clock-history"></i> Custo Técnico Líq.</div>
            <div class="kpi-value">@Fmt(mes.ValorHoraTecLiquida)</div>
            <div class="kpi-sub">@FmtH(mes.TotalHours) horas lançadas</div>
        </div>
        <div class="kpi-card @ResultClass(mes.ValorResultadoLiquido) kpi-highlight">
            <div class="kpi-label"><i class="bi bi-trophy"></i> Resultado Líquido</div>
            <div class="kpi-value">@Fmt(mes.ValorResultadoLiquido)</div>
        </div>
        @{ var margem = mes.ValorAreaLiquido > 0 ? mes.ValorResultadoLiquido / mes.ValorAreaLiquido * 100 : 0; }
        <div class="kpi-card @ResultClass(margem) kpi-highlight">
            <div class="kpi-label"><i class="bi bi-percent"></i> Margem Líquida</div>
            <div class="kpi-value">@margem.ToString("0.0", ptBR)%</div>
            <div class="kpi-sub">Resultado / Receita</div>
        </div>
    </div>

    <!-- Tabs -->
    <div class="tabs-card">
        <div class="tabs-nav">
            <button class="tab-btn active" onclick="switchTab('mes', this)">
                <i class="bi bi-calendar-day"></i> Mês Atual
            </button>
            <button class="tab-btn" onclick="switchTab('media', this)">
                <i class="bi bi-bar-chart-line"></i> Média 3 Meses
            </button>
            <button class="tab-btn" onclick="switchTab('acumulado', this)">
                <i class="bi bi-graph-up"></i> Acumulado 3 Meses
            </button>
        </div>

        <!-- Tab: Mês -->
        <div id="tab-mes" class="tab-content active">
            <div class="tab-metrics">
                @{ RenderMetrics(mes, "Mês Atual"); }
            </div>
            <div class="chart-row">
                <div class="chart-box">
                    <div class="chart-title">Receita vs Custo</div>
                    <canvas id="chartMes"></canvas>
                </div>
                <div class="chart-box">
                    <div class="chart-title">Composição da Receita</div>
                    <canvas id="chartMesDonut"></canvas>
                </div>
            </div>
        </div>

        <!-- Tab: Média -->
        <div id="tab-media" class="tab-content">
            <div class="tab-metrics">
                @{ RenderMetrics(media, "Média Mensal (3 meses)"); }
            </div>
            <div class="chart-row">
                <div class="chart-box">
                    <div class="chart-title">Receita vs Custo (Média)</div>
                    <canvas id="chartMedia"></canvas>
                </div>
                <div class="chart-box">
                    <div class="chart-title">Composição da Receita</div>
                    <canvas id="chartMediaDonut"></canvas>
                </div>
            </div>
        </div>

        <!-- Tab: Acumulado -->
        <div id="tab-acumulado" class="tab-content">
            <div class="tab-metrics">
                @{ RenderMetrics(acumulado, "Acumulado (3 meses)"); }
            </div>
            <div class="chart-row">
                <div class="chart-box">
                    <div class="chart-title">Receita vs Custo (Acumulado)</div>
                    <canvas id="chartAcumulado"></canvas>
                </div>
                <div class="chart-box">
                    <div class="chart-title">Composição da Receita</div>
                    <canvas id="chartAcumuladoDonut"></canvas>
                </div>
            </div>
        </div>
    </div>

</div>

@functions {
    void RenderMetrics(ClockTrack.Models.ViewModels.MensalistaHoursViewModel d, string label)
    {
        if (d == null) { <p class="no-data">Sem dados para este período.</p> return; }
        var ptBR = System.Globalization.CultureInfo.GetCultureInfo("pt-BR");
        string Fmt(decimal v) => v.ToString("N2", ptBR);
        int wh = (int)d.TotalHours; int wm = (int)Math.Round((d.TotalHours - wh) * 60);
        <div class="metrics-row">
            <div class="metric"><span class="metric-label">Horas</span><span class="metric-val hours">@($"{wh:D2}:{wm:D2}")</span></div>
            <div class="metric"><span class="metric-label">Hora Téc. Bruta</span><span class="metric-val">@Fmt(d.ValorTotalHoras)</span></div>
            <div class="metric"><span class="metric-label">Hora Téc. Líquida</span><span class="metric-val">@Fmt(d.ValorHoraTecLiquida)</span></div>
            <div class="metric"><span class="metric-label">Receita Área Bruta</span><span class="metric-val">@Fmt(d.ValorAreaBruto)</span></div>
            <div class="metric"><span class="metric-label">Receita Área Líquida</span><span class="metric-val">@Fmt(d.ValorAreaLiquido)</span></div>
            <div class="metric"><span class="metric-label">Resultado Bruto</span><span class="metric-val @(d.ValorResultadoBruto >= 0 ? "pos" : "neg")">@Fmt(d.ValorResultadoBruto)</span></div>
            <div class="metric"><span class="metric-label">Resultado Líquido</span><span class="metric-val @(d.ValorResultadoLiquido >= 0 ? "pos" : "neg")">@Fmt(d.ValorResultadoLiquido)</span></div>
        </div>
    }
}

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    // Data from server
    const data = {
        mes: {
            receita: @mes.ValorAreaLiquido.ToString(System.Globalization.CultureInfo.InvariantCulture),
            custo: @mes.ValorHoraTecLiquida.ToString(System.Globalization.CultureInfo.InvariantCulture),
            resultado: @mes.ValorResultadoLiquido.ToString(System.Globalization.CultureInfo.InvariantCulture),
            mensalBruto: @mes.Mensalista.ValorMensalBruto.ToString(System.Globalization.CultureInfo.InvariantCulture),
            tributos: @mes.Tributos.ToString(System.Globalization.CultureInfo.InvariantCulture),
            comissoes: @((mes.Mensalista.ComissaoParceiro + mes.Mensalista.ComissaoSocio).ToString(System.Globalization.CultureInfo.InvariantCulture))
        },
        media: {
            receita: @(media?.ValorAreaLiquido.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "0"),
            custo: @(media?.ValorHoraTecLiquida.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "0"),
            resultado: @(media?.ValorResultadoLiquido.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "0"),
            mensalBruto: @(media?.Mensalista.ValorMensalBruto.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "0"),
            tributos: @(media?.Tributos.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "0"),
            comissoes: @(media != null ? (media.Mensalista.ComissaoParceiro + media.Mensalista.ComissaoSocio).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0")
        },
        acumulado: {
            receita: @(acumulado?.ValorAreaLiquido.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "0"),
            custo: @(acumulado?.ValorHoraTecLiquida.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "0"),
            resultado: @(acumulado?.ValorResultadoLiquido.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "0"),
            mensalBruto: @(acumulado?.Mensalista.ValorMensalBruto.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "0"),
            tributos: @(acumulado?.Tributos.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "0"),
            comissoes: @(acumulado != null ? (acumulado.Mensalista.ComissaoParceiro + acumulado.Mensalista.ComissaoSocio).ToString(System.Globalization.CultureInfo.InvariantCulture) : "0")
        }
    };

    function makeBarChart(id, d) {
        const resultColor = d.resultado >= 0 ? 'rgba(34,197,94,0.8)' : 'rgba(239,68,68,0.8)';
        new Chart(document.getElementById(id), {
            type: 'bar',
            data: {
                labels: ['Receita Área Líq.', 'Custo Técnico Líq.', 'Resultado Líq.'],
                datasets: [{
                    data: [d.receita, d.custo, d.resultado],
                    backgroundColor: ['rgba(102,126,234,0.8)', 'rgba(251,191,36,0.8)', resultColor],
                    borderRadius: 6
                }]
            },
            options: {
                responsive: true, plugins: { legend: { display: false } },
                scales: { y: { ticks: { callback: v => 'R$ ' + v.toLocaleString('pt-BR') } } }
            }
        });
    }

    function makeDonutChart(id, d) {
        new Chart(document.getElementById(id), {
            type: 'doughnut',
            data: {
                labels: ['Líquido (área)', 'Tributos', 'Comissões'],
                datasets: [{
                    data: [d.receita, d.tributos * (d.receita / (d.mensalBruto || 1)), d.comissoes * (d.receita / (d.mensalBruto || 1))],
                    backgroundColor: ['rgba(102,126,234,0.85)', 'rgba(251,191,36,0.85)', 'rgba(167,139,250,0.85)'],
                    borderWidth: 2, borderColor: '#fff'
                }]
            },
            options: { responsive: true, plugins: { legend: { position: 'bottom' } }, cutout: '65%' }
        });
    }

    function switchTab(name, btn) {
        document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.getElementById('tab-' + name).classList.add('active');
        btn.classList.add('active');
    }

    window.addEventListener('DOMContentLoaded', () => {
        makeBarChart('chartMes', data.mes);
        makeDonutChart('chartMesDonut', data.mes);
        makeBarChart('chartMedia', data.media);
        makeDonutChart('chartMediaDonut', data.media);
        makeBarChart('chartAcumulado', data.acumulado);
        makeDonutChart('chartAcumuladoDonut', data.acumulado);
    });
</script>

<style>
    .dash-container { max-width: 1200px; margin: 0 auto; padding: 20px; }

    .dash-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 12px; padding: 24px 28px; margin-bottom: 24px;
        display: flex; justify-content: space-between; align-items: center;
        box-shadow: 0 6px 25px rgba(102,126,234,0.25);
    }
    .dash-header-left { display: flex; align-items: center; gap: 16px; }
    .dash-header-icon {
        width: 50px; height: 50px; background: rgba(255,255,255,0.2);
        border-radius: 12px; display: flex; align-items: center; justify-content: center;
        font-size: 24px; color: white;
    }
    .dash-header h1 { font-size: 22px; font-weight: 700; color: white; margin: 0 0 4px; }
    .dash-header p { font-size: 13px; color: rgba(255,255,255,0.85); margin: 0; }
    .btn-back {
        display: flex; align-items: center; gap: 8px; padding: 10px 20px;
        background: white; color: #667eea; border-radius: 8px; font-size: 14px;
        font-weight: 600; text-decoration: none; transition: all 0.2s;
    }
    .btn-back:hover { transform: translateY(-2px); color: #764ba2; }

    .kpi-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
    .kpi-card {
        background: white; border-radius: 12px; padding: 20px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06); border-left: 4px solid #e2e8f0;
    }
    .kpi-card.kpi-positive { border-left-color: #48bb78; }
    .kpi-card.kpi-negative { border-left-color: #fc8181; }
    .kpi-card.kpi-highlight { background: #f7faff; }
    .kpi-card.kpi-positive .kpi-value { color: #22543d; }
    .kpi-card.kpi-negative .kpi-value { color: #742a2a; }
    .kpi-label { font-size: 12px; font-weight: 600; color: #718096; margin-bottom: 8px; display: flex; align-items: center; gap: 6px; }
    .kpi-value { font-size: 22px; font-weight: 800; color: #2d3748; margin-bottom: 6px; }
    .kpi-sub { font-size: 12px; color: #a0aec0; }

    .status-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        font-size: 18px;
    }
    .status-ok { background: #c6f6d5; color: #22543d; }
    .status-warn { background: #fefcbf; color: #744210; }
    .status-danger { background: #fed7d7; color: #742a2a; }

    .tabs-card { background: white; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); overflow: hidden; }
    .tabs-nav { display: flex; border-bottom: 2px solid #e2e8f0; background: #f7fafc; }
    .tab-btn {
        flex: 1; padding: 14px; border: none; background: none; cursor: pointer;
        font-size: 13px; font-weight: 600; color: #718096; display: flex;
        align-items: center; justify-content: center; gap: 6px; transition: all 0.2s;
    }
    .tab-btn.active { color: #667eea; border-bottom: 3px solid #667eea; background: white; margin-bottom: -2px; }
    .tab-btn:hover:not(.active) { background: #edf2f7; color: #4a5568; }

    .tab-content { display: none; padding: 24px; }
    .tab-content.active { display: block; }

    .metrics-row {
        display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 24px;
        padding: 16px; background: #f7fafc; border-radius: 10px;
    }
    .metric { display: flex; flex-direction: column; gap: 4px; min-width: 120px; }
    .metric-label { font-size: 11px; font-weight: 600; color: #718096; text-transform: uppercase; }
    .metric-val { font-size: 15px; font-weight: 700; color: #2d3748; }
    .metric-val.hours { color: #0066cc; }
    .metric-val.pos { color: #22543d; }
    .metric-val.neg { color: #742a2a; }

    .chart-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .chart-box { background: #f7fafc; border-radius: 10px; padding: 16px; }
    .chart-title { font-size: 13px; font-weight: 700; color: #4a5568; margin-bottom: 12px; }

    .no-data { color: #a0aec0; font-size: 14px; padding: 20px 0; }

    @@media (max-width: 900px) {
        .kpi-grid { grid-template-columns: repeat(2, 1fr); }
        .chart-row { grid-template-columns: 1fr; }
        .tabs-nav { flex-direction: column; }
    }
    @@media (max-width: 600px) {
        .kpi-grid { grid-template-columns: 1fr; }
        .dash-header { flex-direction: column; gap: 12px; align-items: stretch; }
    }
</style>
