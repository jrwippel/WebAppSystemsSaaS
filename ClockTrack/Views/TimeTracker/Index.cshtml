@model ClockTrack.Models.ViewModels.ProcessRecordViewModel

<div class="timetracker-container">
    <!-- Timer Card -->
    <div class="timer-card">
        <div class="timer-display">
            <span id="timeDisplay">00:00:00</span>
        </div>
        <button id="startStopButton" onclick="toggleTimer()" class="btn-timer" disabled>
            <i class="fa fa-play"></i>
        </button>
    </div>

    <!-- Form Card -->
    <div class="form-card">
        <div class="form-row">
            <div class="form-field">
                <label data-i18n="timetracker.description">Description</label>
                <input type="text" class="form-control" id="description" data-i18n-placeholder="timetracker.description.placeholder" placeholder="What are you working on?" oninput="checkDescription()" />
            </div>
        </div>

        <div class="form-row">
            <div class="form-field">
                <label data-i18n="timetracker.type">Type</label>
                <div class="input-group-quick">
                    <select asp-for="ProcessRecord.ActivityTypeId" asp-items="Model.ActivityTypesOptions" class="form-control" id="activityTypeSelect"></select>
                    <button type="button" class="btn-quick-add" onclick="openQuickModal('activityType')" title="Add new type">+</button>
                </div>
            </div>
            <div class="form-field">
                <label data-i18n="timetracker.client">Client</label>
                <div class="input-group-quick">
                    <select asp-for="ProcessRecord.ClientId" asp-items="Model.ClientsOptions" class="form-control" id="clientSelect"></select>
                    <button type="button" class="btn-quick-add" onclick="openQuickModal('client')" title="Add new client">+</button>
                </div>
            </div>
            <div class="form-field">
                <label data-i18n="timetracker.area">Area</label>
                <div class="input-group-quick">
                    <select asp-for="ProcessRecord.DepartmentId" asp-items="Model.DepartmentsOptions" class="form-control" id="departmentSelect"></select>
                    <button type="button" class="btn-quick-add" onclick="openQuickModal('department')" title="Add new area">+</button>
                </div>
            </div>
            <div class="form-field">
                <label data-i18n="timetracker.requester">Requester</label>
                <input type="text" asp-for="Solicitante" class="form-control" id="solicitante" data-i18n-placeholder="timetracker.requester.placeholder" placeholder="Requester name" />
            </div>
        </div>
    </div>

    <!-- Records Card -->
    <div class="records-card">
        <div class="records-header">
            <h3><i class="bi bi-clock-history"></i> <span data-i18n="timetracker.records">All Records</span></h3>
            <input type="text" id="searchInput" data-i18n-placeholder="timetracker.search" placeholder="Search..." class="search-input" />
        </div>

        <div class="table-container">
            <table class="table" id="recordsTable">
                <thead>
                    <tr>
                        <th style="width: 100px;" data-i18n="timetracker.table.date">Date</th>
                        <th style="width: 70px;" data-i18n="timetracker.table.start">Start</th>
                        <th style="width: 70px;" data-i18n="timetracker.table.end">End</th>
                        <th style="width: 100px;" data-i18n="timetracker.table.duration">Duration</th>
                        <th style="max-width: 250px;" data-i18n="timetracker.table.description">Description</th>
                        <th style="width: 150px;" data-i18n="timetracker.table.client">Client</th>
                        <th style="width: 120px;" data-i18n="timetracker.table.requester">Requester</th>
                        <th style="width: 120px;" data-i18n="timetracker.table.type">Type</th>
                        <th style="width: 60px;"></th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>

        <!-- Paginação -->
        <div class="pagination-container">
            <div class="pagination-info">
                <span id="paginationInfo"></span>
            </div>
            <div class="pagination-controls">
                <button id="prevPage" class="btn-pagination" onclick="changePage(-1)">
                    <i class="fa fa-chevron-left"></i> Previous
                </button>
                <span id="pageNumbers" class="page-numbers"></span>
                <button id="nextPage" class="btn-pagination" onclick="changePage(1)">
                    Next <i class="fa fa-chevron-right"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<div id="error-message" class="alert alert-danger" style="display: none;"></div>

<!-- Quick Create Modals -->
<div id="quickModal" class="quick-modal-overlay" style="display:none;" onclick="closeQuickModal(event)">
    <div class="quick-modal-box">
        <div class="quick-modal-header">
            <span id="quickModalTitle">Add</span>
            <button type="button" class="quick-modal-close" onclick="closeQuickModal()">&times;</button>
        </div>
        <div class="quick-modal-body">
            <div id="quickFieldName" class="quick-field">
                <label>Name</label>
                <input type="text" id="quickInputName" class="form-control" placeholder="Enter name..." />
            </div>
            <div id="quickFieldColor" class="quick-field" style="display:none;">
                <label>Color</label>
                <input type="color" id="quickInputColor" value="#667eea" class="form-control" style="height:42px;padding:4px 8px;" />
            </div>
        </div>
        <div class="quick-modal-footer">
            <button type="button" class="btn-quick-cancel" onclick="closeQuickModal()">Cancel</button>
            <button type="button" class="btn-quick-save" id="quickSaveBtn" onclick="saveQuickCreate()">Save</button>
        </div>
    </div>
</div>

