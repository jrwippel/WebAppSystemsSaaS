@section Scripts {
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
    <script>
        let timerInterval;
        let startTime;
        let isRunning = false;
        let processRecordId;
        let loggedUserId = '@ViewBag.LoggedUserId';
        let currentPage = 1;
        let totalPages = 1;
        let searchTimeout;

        // Criar mapa de tipos de atividade dinamicamente
        const activityTypeMap = {};
        @foreach (var activityType in Model.ActivityTypesOptions)
        {
            <text>activityTypeMap[@activityType.Value] = "@activityType.Text";</text>
        }

        document.addEventListener("DOMContentLoaded", function () {
            const clientField = document.querySelector('select[name="ProcessRecord.ClientId"]');
            const solicitanteField = document.getElementById("solicitante");
            const descriptionField = document.getElementById("description");
            const departmentField = document.querySelector('select[name="ProcessRecord.DepartmentId"]');
            const recordTypeField = document.querySelector('select[name="ProcessRecord.ActivityTypeId"]');
            const startStopButton = document.getElementById("startStopButton");

            // Auto-fill solicitante when client changes
            clientField.addEventListener('change', async function () {
                const clientId = clientField.value;
                if (clientId && clientId !== "0") {
                    try {
                        const response = await fetch(`/TimeTracker/GetSolicitanteByClientId?clientId=${clientId}`);
                        if (response.ok) {
                            const data = await response.json();
                            if (data && data.solicitante) {
                                solicitanteField.value = data.solicitante;
                            } else {
                                solicitanteField.value = "";
                            }
                        }
                    } catch (error) {
                        console.error('Erro na requisição:', error);
                    }
                } else {
                    solicitanteField.value = "";
                }
                validateFields();
            });

            // Validate fields
            function validateFields() {
                const isDescriptionValid = descriptionField.value.trim() !== "";
                const isClientValid = clientField.value !== "" && clientField.value !== "0";
                const isDepartmentValid = departmentField.value !== "" && departmentField.value !== "0";
                const isSolicitanteValid = solicitanteField.value.trim() !== "";

                if (isDescriptionValid && isClientValid && isDepartmentValid && isSolicitanteValid) {
                    startStopButton.disabled = false;
                } else {
                    startStopButton.disabled = true;
                }
            }

            descriptionField.addEventListener('input', validateFields);
            departmentField.addEventListener('change', validateFields);
            solicitanteField.addEventListener('input', validateFields);
            recordTypeField.addEventListener('change', validateFields);

            // Busca com debounce
            const searchInput = document.getElementById("searchInput");
            searchInput.addEventListener('input', function() {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(() => {
                    currentPage = 1;
                    loadRecordsForToday(loggedUserId);
                }, 500);
            });

            checkDescription();
            loadRecordsForToday(loggedUserId);
            checkActiveTimer();
        });

        async function checkActiveTimer() {
            try {
                const response = await fetch(`/TimeTracker/GetActiveTimer?attorneyId=${loggedUserId}`);
                if (response.ok) {
                    const data = await response.json();
                    if (data && data.horaInicial) {
                        processRecordId = data.processRecordId;

                        // Calcula o startTime como "agora menos o tempo já decorrido"
                        // para que o timer mostre o tempo total correto independente de fuso
                        const [hours, minutes, seconds] = data.horaInicial.split(':').map(Number);
                        const dateStr = data.date.split('T')[0];
                        const [year, month, day] = dateStr.split('-').map(Number);
                        
                        // Hora de início no fuso de Brasília (UTC-3)
                        const startInBrasilia = new Date(Date.UTC(year, month - 1, day, hours + 3, minutes, seconds));
                        
                        // Calcula elapsed desde o início até agora
                        const nowUtc = new Date();
                        const elapsedMs = nowUtc - startInBrasilia;
                        
                        // startTime = agora - elapsed (para que updateTime calcule corretamente)
                        startTime = new Date(nowUtc - elapsedMs);

                        timerInterval = setInterval(updateTime, 1000);
                        isRunning = true;

                        // Start floating timer
                        if (window.startFloatingTimer) {
                            window.startFloatingTimer(startTime);
                        }

                        const button = document.getElementById("startStopButton");
                        button.innerHTML = '<i class="fa fa-stop"></i>';
                        button.classList.add('running');
                        button.disabled = false;

                        document.querySelectorAll(".btn-play").forEach(btn => btn.disabled = true);
                        
                        document.getElementById("description").value = data.description;
                        document.querySelector('select[name="ProcessRecord.ClientId"]').value = data.clientId;
                        document.querySelector('select[name="ProcessRecord.DepartmentId"]').value = data.departmentId;
                        document.getElementById("solicitante").value = data.solicitante;
                        document.querySelector('select[name="ProcessRecord.ActivityTypeId"]').value = data.activityTypeId;
                    }
                }
            } catch (error) {
                console.error('Erro ao recuperar o estado do cronômetro', error);
            }
        }

        async function loadRecordsForToday(attorneyId) {
            try {
                const searchValue = document.getElementById("searchInput").value;
                const url = `/TimeTracker/GetRecordsForToday?attorneyId=${attorneyId}&page=${currentPage}&pageSize=10&search=${encodeURIComponent(searchValue)}`;
                console.log('Fetching records from:', url);
                
                const response = await fetch(url);
                console.log('Response status:', response.status);
                
                if (response.ok) {
                    const data = await response.json();
                    console.log('Data received:', data);
                    
                    // Suporta tanto array direto quanto objeto com propriedades
                    let records, totalPagesValue, totalRecordsValue, currentPageValue;
                    
                    if (Array.isArray(data)) {
                        // Formato antigo - array direto
                        records = data;
                        totalPagesValue = 1;
                        totalRecordsValue = data.length;
                        currentPageValue = 1;
                    } else {
                        // Formato novo - objeto com propriedades
                        records = data.records || [];
                        totalPagesValue = data.totalPages || 1;
                        totalRecordsValue = data.totalRecords || 0;
                        currentPageValue = data.currentPage || 1;
                    }
                    
                    totalPages = totalPagesValue;
                    
                    const tableBody = document.querySelector("#recordsTable tbody");
                    tableBody.innerHTML = "";

                    if (!records || records.length === 0) {
                        tableBody.innerHTML = '<tr><td colspan="9" style="text-align: center; padding: 40px; color: #718096;">No records found</td></tr>';
                    } else {
                        records.forEach(record => {
                            const startTime = new Date(`1970-01-01T${record.horaInicial}Z`);
                            const endTime = new Date(`1970-01-01T${record.horaFinal}Z`);
                            const duration = calculateDuration(startTime, endTime);
                            const formattedDate = new Date(record.date).toLocaleDateString("pt-BR");
                            
                            // Formatar horas para HH:MM
                            const startTimeFormatted = record.horaInicial.substring(0, 5);
                            const endTimeFormatted = record.horaFinal.substring(0, 5);

                            const row = document.createElement("tr");
                            row.innerHTML = `
                                <td style="width: 100px;">${formattedDate}</td>
                                <td style="width: 70px;">${startTimeFormatted}</td>
                                <td style="width: 70px;">${endTimeFormatted}</td>
                                <td style="width: 100px;"><span class="duration-badge">${duration}</span></td>
                                <td class="description-cell" style="max-width: 250px;" title="${record.description}">${record.description}</td>
                                <td style="width: 150px;" title="${record.clienteNome}">${record.clienteNome}</td>
                                <td style="width: 120px;" title="${record.solicitante || ''}">${record.solicitante || ''}</td>
                                <td style="width: 120px;"><span class="type-badge">${activityTypeMap[record.activityTypeId] || 'N/A'}</span></td>
                                <td style="width: 60px; text-align: center; white-space: nowrap;">
                                    <button class="btn-play" onclick="startTimerFromRecord(${record.id})" ${isRunning ? 'disabled' : ''}>
                                        <i class="fa fa-play"></i>
                                    </button>
                                </td>
                            `;
                            tableBody.appendChild(row);
                        });
                    }

                    updatePaginationControls({
                        records,
                        currentPage: currentPageValue,
                        totalPages: totalPagesValue,
                        totalRecords: totalRecordsValue,
                        pageSize: 10
                    });
                } else {
                    console.error('Response not OK:', response.status, response.statusText);
                    const tableBody = document.querySelector("#recordsTable tbody");
                    tableBody.innerHTML = '<tr><td colspan="9" style="text-align: center; padding: 40px; color: #e53e3e;">Error loading records. Please refresh the page.</td></tr>';
                }
            } catch (error) {
                console.error('Erro ao carregar registros:', error);
                const tableBody = document.querySelector("#recordsTable tbody");
                tableBody.innerHTML = '<tr><td colspan="9" style="text-align: center; padding: 40px; color: #e53e3e;">Error loading records. Please refresh the page.</td></tr>';
            }
        }

        function updatePaginationControls(data) {
            const paginationInfo = document.getElementById("paginationInfo");
            const pageNumbers = document.getElementById("pageNumbers");
            const prevButton = document.getElementById("prevPage");
            const nextButton = document.getElementById("nextPage");

            // Atualizar informações
            const startRecord = data.totalRecords === 0 ? 0 : ((data.currentPage - 1) * data.pageSize) + 1;
            const endRecord = Math.min(data.currentPage * data.pageSize, data.totalRecords);
            paginationInfo.textContent = `Showing ${startRecord}-${endRecord} of ${data.totalRecords} records`;

            // Atualizar botões
            prevButton.disabled = data.currentPage === 1;
            nextButton.disabled = data.currentPage === data.totalPages || data.totalPages === 0;

            // Gerar números de página
            pageNumbers.innerHTML = '';
            const maxVisiblePages = 5;
            let startPage = Math.max(1, data.currentPage - Math.floor(maxVisiblePages / 2));
            let endPage = Math.min(data.totalPages, startPage + maxVisiblePages - 1);

            if (endPage - startPage < maxVisiblePages - 1) {
                startPage = Math.max(1, endPage - maxVisiblePages + 1);
            }

            for (let i = startPage; i <= endPage; i++) {
                const pageBtn = document.createElement('span');
                pageBtn.className = 'page-number' + (i === data.currentPage ? ' active' : '');
                pageBtn.textContent = i;
                pageBtn.onclick = () => goToPage(i);
                pageNumbers.appendChild(pageBtn);
            }
        }

        function changePage(delta) {
            const newPage = currentPage + delta;
            if (newPage >= 1 && newPage <= totalPages) {
                currentPage = newPage;
                loadRecordsForToday(loggedUserId);
            }
        }

        function goToPage(page) {
            currentPage = page;
            loadRecordsForToday(loggedUserId);
        }

        async function startTimerFromRecord(recordId) {
            try {
                const response = await fetch(`/TimeTracker/GetRecordById?recordId=${recordId}`);
                if (response.ok) {
                    const record = await response.json();
                    
                    // Apenas copia os dados do registro (não a hora)
                    document.getElementById("description").value = record.description;
                    document.querySelector('select[name="ProcessRecord.ClientId"]').value = record.clientId;
                    document.querySelector('select[name="ProcessRecord.DepartmentId"]').value = record.departmentId;
                    document.getElementById("solicitante").value = record.solicitante;
                    document.querySelector('select[name="ProcessRecord.ActivityTypeId"]').value = record.activityTypeId;
                    
                    // Valida os campos antes de iniciar
                    const clientField = document.querySelector('select[name="ProcessRecord.ClientId"]');
                    const departmentField = document.querySelector('select[name="ProcessRecord.DepartmentId"]');
                    const solicitanteField = document.getElementById("solicitante");
                    const descriptionField = document.getElementById("description");
                    
                    const isValid = descriptionField.value.trim() !== "" &&
                                  clientField.value !== "" && clientField.value !== "0" &&
                                  departmentField.value !== "" && departmentField.value !== "0" &&
                                  solicitanteField.value.trim() !== "";
                    
                    if (isValid) {
                        // Inicia o timer com a hora ATUAL (não usa a hora do registro antigo)
                        toggleTimer();
                    } else {
                        alert('Preencha todos os campos antes de iniciar o timer.');
                    }
                }
            } catch (error) {
                console.error('Erro ao carregar o registro:', error);
            }
        }

        function calculateDuration(startTime, endTime) {
            const diffMs = endTime - startTime;
            const diffHrs = Math.floor(diffMs / (1000 * 60 * 60));
            const diffMins = Math.floor((diffMs % (1000 * 60 * 60)) / (1000 * 60));
            const diffSecs = Math.floor((diffMs % (1000 * 60)) / 1000);
            return `${String(diffHrs).padStart(2, '0')}:${String(diffMins).padStart(2, '0')}:${String(diffSecs).padStart(2, '0')}`;
        }

        function checkDescription() {
            const description = document.getElementById("description").value;
            const button = document.getElementById("startStopButton");
            if (!description.trim()) {
                button.disabled = true;
            }
        }

        async function toggleTimer() {
            const button = document.getElementById("startStopButton");
            if (!isRunning) {
                await startTimer();
                button.innerHTML = '<i class="fa fa-stop"></i>';
                button.classList.add('running');
                button.disabled = false;
                document.querySelectorAll(".btn-play").forEach(btn => btn.disabled = true);
            } else {
                await stopTimer();
                button.innerHTML = '<i class="fa fa-play"></i>';
                button.classList.remove('running');
                button.disabled = true;
                document.querySelectorAll(".btn-play").forEach(btn => btn.disabled = false);
            }
        }

        async function startTimer() {
            startKeepAlive();
            const description = document.getElementById("description").value;
            const clientId = document.querySelector('select[name="ProcessRecord.ClientId"]').value;
            const departmentId = document.querySelector('select[name="ProcessRecord.DepartmentId"]').value;
            const solicitante = document.getElementById("solicitante").value;
            const activityTypeId = document.querySelector('select[name="ProcessRecord.ActivityTypeId"]').value;

            startTime = new Date();
            const response = await fetch('/TimeTracker/StartTimer', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    description: description,
                    clientId: clientId,
                    departmentId: departmentId,
                    solicitante: solicitante,
                    attorneyId: loggedUserId,
                    activityTypeId: activityTypeId
                })
            });

            if (response.ok) {
                processRecordId = await response.json();
                timerInterval = setInterval(updateTime, 1000);
                isRunning = true;
                
                // Start floating timer
                if (window.startFloatingTimer) {
                    window.startFloatingTimer(startTime);
                }
            } else {
                const errorText = await response.text();
                alert(errorText || 'Erro ao iniciar o timer. Verifique se não há outro timer em execução.');
                
                // Reset button state
                const button = document.getElementById("startStopButton");
                button.innerHTML = '<i class="fa fa-play"></i>';
                button.classList.remove('running');
                
                // Reload page to sync state
                window.location.reload();
            }
        }

        async function stopTimer() {
            const description = document.getElementById("description").value;
            const response = await fetch('/TimeTracker/StopTimer', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    processRecordId: processRecordId,
                    description: description
                })
            });

            if (response.ok) {
                clearInterval(timerInterval);
                isRunning = false;
                document.getElementById("timeDisplay").textContent = "00:00:00";
                document.title = "Time Tracker";

                // Stop floating timer
                if (window.stopFloatingTimerGlobal) {
                    window.stopFloatingTimerGlobal();
                }

                document.getElementById("description").value = "";
                document.querySelector('select[name="ProcessRecord.ClientId"]').value = "0";
                document.querySelector('select[name="ProcessRecord.DepartmentId"]').value = "0";
                document.getElementById("solicitante").value = "";
                document.querySelector('select[name="ProcessRecord.ActivityTypeId"]').value = "0";

                await loadRecordsForToday(loggedUserId);
            }
        }

        function updateTime() {
            const now = new Date();
            const elapsed = Math.floor((now - startTime) / 1000);
            const hours = String(Math.floor(elapsed / 3600)).padStart(2, '0');
            const minutes = String(Math.floor((elapsed % 3600) / 60)).padStart(2, '0');
            const seconds = String(elapsed % 60).padStart(2, '0');

            document.getElementById("timeDisplay").textContent = `${hours}:${minutes}:${seconds}`;
            document.title = `${hours}:${minutes}:${seconds} - Time Tracker`;
        }

        function startKeepAlive() {
            setInterval(() => {
                fetch('/TimeTracker/KeepAlive')
                    .then(response => response.ok ? console.log('Keep-alive OK') : console.warn('Erro no keep-alive'))
                    .catch(error => console.error('Erro na requisição de keep-alive:', error));
            }, 300000);
        }

        // ---- Quick Create ----
        let quickModalType = null;

        const quickModalConfig = {
            activityType: {
                title: 'New Activity Type',
                url: '/api/ActivityTypesApi/QuickCreate',
                selectId: 'activityTypeSelect',
                hasColor: true
            },
            client: {
                title: 'New Client',
                url: '/api/ClientsApi/QuickCreate',
                selectId: 'clientSelect',
                hasColor: false
            },
            department: {
                title: 'New Area',
                url: '/api/DepartmentsApi/QuickCreate',
                selectId: 'departmentSelect',
                hasColor: false
            }
        };

        function openQuickModal(type) {
            quickModalType = type;
            const config = quickModalConfig[type];
            document.getElementById('quickModalTitle').textContent = config.title;
            document.getElementById('quickInputName').value = '';
            document.getElementById('quickInputColor').value = '#667eea';
            document.getElementById('quickFieldColor').style.display = config.hasColor ? 'block' : 'none';
            document.getElementById('quickModal').style.display = 'flex';
            setTimeout(() => document.getElementById('quickInputName').focus(), 50);
        }

        function closeQuickModal(event) {
            if (event && event.target !== document.getElementById('quickModal')) return;
            document.getElementById('quickModal').style.display = 'none';
            quickModalType = null;
        }

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeQuickModal();
            if (e.key === 'Enter' && quickModalType) saveQuickCreate();
        });

        async function saveQuickCreate() {
            const config = quickModalConfig[quickModalType];
            const name = document.getElementById('quickInputName').value.trim();
            const color = document.getElementById('quickInputColor').value;

            if (!name) {
                document.getElementById('quickInputName').focus();
                return;
            }

            const saveBtn = document.getElementById('quickSaveBtn');
            saveBtn.disabled = true;
            saveBtn.textContent = 'Saving...';

            try {
                const body = config.hasColor ? { name, color } : { name };
                const response = await fetch(config.url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });

                if (response.ok) {
                    const item = await response.json();
                    const select = document.getElementById(config.selectId);
                    const option = new Option(item.name, item.id);
                    select.add(option);
                    select.value = item.id;

                    // Update activityTypeMap if needed
                    if (quickModalType === 'activityType') {
                        activityTypeMap[item.id] = item.name;
                    }

                    // Trigger change event for validation
                    select.dispatchEvent(new Event('change'));

                    document.getElementById('quickModal').style.display = 'none';
                    quickModalType = null;
                } else {
                    const err = await response.text();
                    alert('Error: ' + err);
                }
            } catch (e) {
                alert('Request failed. Please try again.');
            } finally {
                saveBtn.disabled = false;
                saveBtn.textContent = 'Save';
            }
        }
    </script>
}
