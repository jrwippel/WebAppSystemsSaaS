@model ClockTrack.Models.ProcessRecord

@{
    ViewData["Title"] = "Excluir Atividade";
}

<div class="delete-container">
    <!-- Header -->
    <div class="page-header">
        <div class="header-content">
            <div class="header-icon">
                <i class="bi bi-exclamation-triangle"></i>
            </div>
            <div class="header-text">
                <h1 class="page-title" data-i18n="activity.delete.title">Excluir Atividade</h1>
                <p class="page-subtitle" data-i18n="activity.delete.subtitle">Confirme a exclusão da atividade</p>
            </div>
        </div>
    </div>

    <!-- Delete Card -->
    <div class="delete-card">
        <!-- Warning Message -->
        <div class="warning-box">
            <i class="bi bi-exclamation-circle"></i>
            <div class="warning-content">
                <h3 data-i18n="activity.delete.warning">Tem certeza que deseja excluir esta atividade?</h3>
                <p data-i18n="activity.delete.message">Esta ação não pode ser desfeita. Todos os dados desta atividade serão permanentemente removidos.</p>
            </div>
        </div>

        <!-- Activity Summary -->
        <div class="summary-box">
            <div class="summary-title">
                <i class="bi bi-info-circle"></i>
                <span data-i18n="activity.delete.summary">Resumo da Atividade</span>
            </div>
            
            <div class="summary-grid">
                <div class="summary-item">
                    <label><i class="bi bi-calendar3"></i> <span data-i18n="activity.field.date">Data</span></label>
                    <div class="summary-value">@Model.Date.ToString("dd/MM/yyyy")</div>
                </div>
                
                <div class="summary-item">
                    <label><i class="bi bi-clock"></i> <span data-i18n="activity.field.time">Horário</span></label>
                    <div class="summary-value">@Model.HoraInicial - @Model.HoraFinal</div>
                </div>
                
                <div class="summary-item">
                    <label><i class="bi bi-hourglass-split"></i> <span data-i18n="activity.duration">Duração</span></label>
                    <div class="summary-value">
                        <span class="hours-badge">@Model.CalculoHoras()</span>
                    </div>
                </div>
                
                <div class="summary-item">
                    <label><i class="bi bi-briefcase"></i> <span data-i18n="activity.field.client">Cliente</span></label>
                    <div class="summary-value">@Model.Client.Name</div>
                </div>
                
                <div class="summary-item">
                    <label><i class="bi bi-tag"></i> <span data-i18n="activity.field.type">Tipo</span></label>
                    <div class="summary-value">
                        <span class="type-badge">@(Model.ActivityType?.Name ?? "N/A")</span>
                    </div>
                </div>
                
                <div class="summary-item">
                    <label><i class="bi bi-person-badge"></i> <span data-i18n="activity.field.user">Usuário</span></label>
                    <div class="summary-value">@Model.Attorney.Name</div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="description-preview">
                    <label><i class="bi bi-file-text"></i> <span data-i18n="activity.field.description">Descrição</span></label>
                    <div class="description-text">@Model.Description</div>
                </div>
            }
        </div>

        <!-- Action Buttons -->
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="delete-actions">
                <button type="submit" class="btn btn-delete">
                    <i class="bi bi-trash"></i>
                    <span data-i18n="common.delete">Excluir</span>
                </button>
                <a asp-action="Index" class="btn btn-cancel">
                    <i class="bi bi-x-circle"></i>
                    <span data-i18n="common.cancel">Cancelar</span>
                </a>
            </div>
        </form>
    </div>
</div>

<style>
    .delete-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 20px;
    }

    .page-header {
        background: linear-gradient(135deg, #f56565 0%, #e53e3e 100%);
        border-radius: 12px;
        padding: 24px 28px;
        margin-bottom: 24px;
        box-shadow: 0 6px 25px rgba(245, 101, 101, 0.25);
    }

    .header-content {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .header-icon {
        width: 50px;
        height: 50px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: white;
        backdrop-filter: blur(10px);
    }

    .page-title {
        font-size: 24px;
        font-weight: 700;
        color: white;
        margin: 0 0 6px 0;
    }

    .page-subtitle {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.9);
        margin: 0;
    }

    .delete-card {
        background: white;
        border-radius: 12px;
        padding: 30px;
        box-shadow: 0 2px 15px rgba(0, 0, 0, 0.05);
    }

    .warning-box {
        display: flex;
        gap: 16px;
        padding: 20px;
        background: #fff5f5;
        border: 2px solid #feb2b2;
        border-radius: 10px;
        margin-bottom: 25px;
    }

    .warning-box > i {
        font-size: 32px;
        color: #e53e3e;
        flex-shrink: 0;
    }

    .warning-content h3 {
        font-size: 16px;
        font-weight: 600;
        color: #c53030;
        margin: 0 0 8px 0;
    }

    .warning-content p {
        font-size: 13px;
        color: #742a2a;
        margin: 0;
        line-height: 1.5;
    }

    .summary-box {
        padding: 20px;
        background: #f7fafc;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        margin-bottom: 25px;
    }

    .summary-title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 15px;
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 18px;
        padding-bottom: 12px;
        border-bottom: 2px solid #e2e8f0;
    }

    .summary-title i {
        font-size: 18px;
        color: #667eea;
    }

    .summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 16px;
        margin-bottom: 16px;
    }

    .summary-item {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .summary-item label {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 11px;
        font-weight: 600;
        color: #718096;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .summary-item label i {
        font-size: 13px;
        color: #667eea;
    }

    .summary-value {
        font-size: 14px;
        color: #2d3748;
        font-weight: 500;
        padding: 8px 12px;
        background: white;
        border-radius: 6px;
        border-left: 3px solid #667eea;
    }

    .type-badge {
        display: inline-block;
        padding: 4px 12px;
        background: #e2e8f0;
        color: #4a5568;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 600;
    }

    .hours-badge {
        display: inline-block;
        padding: 4px 12px;
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.15) 100%);
        color: #667eea;
        border-radius: 12px;
        font-weight: 600;
        font-size: 13px;
    }

    .description-preview {
        padding-top: 16px;
        border-top: 1px solid #e2e8f0;
    }

    .description-preview label {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 11px;
        font-weight: 600;
        color: #718096;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 8px;
    }

    .description-preview label i {
        font-size: 13px;
        color: #667eea;
    }

    .description-text {
        padding: 12px;
        background: white;
        border-radius: 6px;
        border-left: 3px solid #667eea;
        font-size: 13px;
        line-height: 1.6;
        color: #2d3748;
        white-space: pre-wrap;
        max-height: 120px;
        overflow-y: auto;
    }

    .delete-actions {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
    }

    .btn {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 24px;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .btn-delete {
        background: linear-gradient(135deg, #f56565 0%, #e53e3e 100%);
        color: white;
        box-shadow: 0 4px 12px rgba(245, 101, 101, 0.3);
    }

    .btn-delete:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(245, 101, 101, 0.4);
    }

    .btn-cancel {
        background: white;
        color: #4a5568;
        border: 2px solid #e2e8f0;
    }

    .btn-cancel:hover {
        background: #f7fafc;
        border-color: #cbd5e0;
        transform: translateY(-2px);
        color: #2d3748;
    }

    @@media (max-width: 768px) {
        .delete-container {
            padding: 12px;
        }

        .page-header {
            padding: 18px 20px;
        }

        .delete-card {
            padding: 20px;
        }

        .summary-grid {
            grid-template-columns: 1fr;
        }

        .delete-actions {
            flex-direction: column-reverse;
        }

        .btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>
